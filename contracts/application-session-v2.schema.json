{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/application-session-v2.schema.json",
  "title": "ApplicationSessionV2",
  "description": "Prompt Application 专用 metadata-only Session；不保存 transcript、变量或模型输出。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "tenant_ref", "workspace_id", "application_id", "owner_subject_ref", "state", "record_version", "profile_binding", "authority", "content_retention", "turn_count", "last_turn_id", "created_at", "updated_at", "closed_at", "created_by_actor_ref", "updated_by_actor_ref", "request_id", "audit_ref"],
  "properties": {
    "schema_version": {"const": "application_session.v2"},
    "session_id": {"type": "string", "pattern": "^appsess_[a-z2-7]{16}$"},
    "tenant_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "workspace_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "application_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/applicationId"},
    "owner_subject_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "state": {"enum": ["active", "closed"]},
    "record_version": {"type": "integer", "minimum": 1},
    "profile_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_profile"],
      "properties": {"execution_profile": {"const": "prompt_application_invocation_v1"}}
    },
    "authority": {"$ref": "application-runtime-authority-v2.schema.json"},
    "content_retention": {"const": "metadata_only"},
    "turn_count": {"type": "integer", "minimum": 0},
    "last_turn_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^appturn_[a-z2-7]{16}$"}]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "closed_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
    "created_by_actor_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "updated_by_actor_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "request_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "audit_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"}
  },
  "allOf": [
    {"if": {"properties": {"state": {"const": "active"}}}, "then": {"properties": {"closed_at": {"type": "null"}}}},
    {"if": {"properties": {"state": {"const": "closed"}}}, "then": {"properties": {"closed_at": {"type": "string", "format": "date-time"}}}}
  ]
}
