{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-definition-release-decision.schema.json",
  "title": "Workflow Definition Release Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_version", "decision", "reason", "reviewer_ref", "reviewed_at", "request_id", "audit_ref"],
  "properties": {
    "schema_version": {"const": "workflow_definition_release_decision.v1"},
    "review_version": {"type": "integer", "minimum": 1},
    "decision": {"enum": ["approve", "reject"]},
    "reason": {"type": "string", "minLength": 4, "maxLength": 500},
    "reviewer_ref": {"type": "string", "minLength": 1, "maxLength": 240},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "request_id": {"type": "string", "minLength": 1, "maxLength": 240},
    "audit_ref": {"type": "string", "minLength": 1, "maxLength": 240}
  }
}
