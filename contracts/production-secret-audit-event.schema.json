{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/production-secret-audit-event.schema.json",
  "title": "ProductionSecretAuditEvent",
  "description": "Metadata-only audit event schema for future production secret backend audit store runtime. This schema does not describe secret values, credential payloads, provider raw URLs, database connections, writer output or delivery runtime state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_version",
    "event_kind",
    "occurred_at",
    "environment",
    "provider",
    "provider_profile",
    "backend_profile_ref",
    "secret_ref_key_status",
    "secret_ref_version_ref",
    "operator_approval_ref",
    "credential_handle_boundary_ref",
    "request_id",
    "audit_ref",
    "policy_version",
    "retention_policy_ref",
    "redaction_profile_ref",
    "idempotency_key_ref",
    "delivery_mode"
  ],
  "properties": {
    "event_id": {
      "$ref": "#/$defs/reference"
    },
    "event_version": {
      "type": "string",
      "const": "audit-event-schema-v1"
    },
    "event_kind": {
      "type": "string",
      "enum": [
        "secret_resolution_requested",
        "secret_resolution_denied",
        "secret_resolution_failed_closed",
        "credential_handle_boundary_checked",
        "operator_approval_evidence_checked",
        "backend_profile_selected",
        "backend_health_gate_checked",
        "no_leakage_gate_checked",
        "rotation_policy_checked",
        "audit_handoff_failed_closed"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": [
        "test",
        "production"
      ]
    },
    "provider": {
      "$ref": "#/$defs/provider_key"
    },
    "provider_profile": {
      "$ref": "#/$defs/provider_key"
    },
    "backend_profile_ref": {
      "$ref": "#/$defs/reference"
    },
    "secret_ref_key_status": {
      "type": "string",
      "enum": [
        "present",
        "missing",
        "not_required"
      ]
    },
    "secret_ref_version_ref": {
      "$ref": "#/$defs/reference"
    },
    "operator_approval_ref": {
      "$ref": "#/$defs/reference"
    },
    "credential_handle_boundary_ref": {
      "$ref": "#/$defs/reference"
    },
    "request_id": {
      "$ref": "#/$defs/reference"
    },
    "audit_ref": {
      "$ref": "#/$defs/reference"
    },
    "policy_version": {
      "$ref": "#/$defs/version_key"
    },
    "retention_policy_ref": {
      "$ref": "#/$defs/reference"
    },
    "redaction_profile_ref": {
      "$ref": "#/$defs/reference"
    },
    "idempotency_key_ref": {
      "$ref": "#/$defs/reference"
    },
    "delivery_mode": {
      "type": "string",
      "enum": [
        "fail_closed"
      ]
    },
    "failure_code": {
      "$ref": "#/$defs/version_key"
    },
    "failure_boundary": {
      "$ref": "#/$defs/version_key"
    },
    "sanitized_diagnostic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "rotation_policy_version": {
      "$ref": "#/$defs/version_key"
    },
    "runbook_version": {
      "$ref": "#/$defs/version_key"
    },
    "approval_ticket_ref": {
      "$ref": "#/$defs/reference"
    },
    "approval_window_ref": {
      "$ref": "#/$defs/reference"
    },
    "backend_health_ref": {
      "$ref": "#/$defs/reference"
    },
    "no_leakage_smoke_ref": {
      "$ref": "#/$defs/reference"
    }
  },
  "allOf": [
    {
      "not": {
        "required": [
          "secret_value"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_secret"
        ]
      }
    },
    {
      "not": {
        "required": [
          "password"
        ]
      }
    },
    {
      "not": {
        "required": [
          "token"
        ]
      }
    },
    {
      "not": {
        "required": [
          "api_key"
        ]
      }
    },
    {
      "not": {
        "required": [
          "provider_raw_url"
        ]
      }
    },
    {
      "not": {
        "required": [
          "resolver_backend_url"
        ]
      }
    },
    {
      "not": {
        "required": [
          "dsn"
        ]
      }
    },
    {
      "not": {
        "required": [
          "database_hostname"
        ]
      }
    },
    {
      "not": {
        "required": [
          "cloud_credential"
        ]
      }
    },
    {
      "not": {
        "required": [
          "credential_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "full_secret_ref_value"
        ]
      }
    },
    {
      "not": {
        "required": [
          "full_credential_handle"
        ]
      }
    },
    {
      "not": {
        "required": [
          "full_operator_identity_claim"
        ]
      }
    },
    {
      "not": {
        "required": [
          "full_user_claim"
        ]
      }
    },
    {
      "not": {
        "required": [
          "authorization_header"
        ]
      }
    },
    {
      "not": {
        "required": [
          "cookie"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_request_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_response_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_audit_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_writer_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_event_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "schema_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "payload_hash"
        ]
      }
    },
    {
      "not": {
        "required": [
          "event_payload_hash"
        ]
      }
    },
    {
      "not": {
        "required": [
          "secret_derived_hash"
        ]
      }
    }
  ],
  "$defs": {
    "provider_key": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_-]{1,63}$"
    },
    "reference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_.-]*:[a-zA-Z0-9][a-zA-Z0-9_.:/-]*$"
    },
    "version_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    }
  }
}
