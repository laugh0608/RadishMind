{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/copilot-request.schema.json",
  "title": "CopilotRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "task",
    "locale",
    "artifacts",
    "context",
    "tool_hints",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "enum": [
        "radishflow",
        "radish"
      ]
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "minLength": 2
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "context": {
      "type": "object"
    },
    "tool_hints": {
      "$ref": "#/$defs/tool_hints"
    },
    "safety": {
      "$ref": "#/$defs/safety"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "project": {
            "const": "radishflow"
          }
        },
        "required": [
          "project"
        ]
      },
      "then": {
        "properties": {
          "task": {
            "enum": [
              "explain_diagnostics",
              "suggest_flowsheet_edits",
              "suggest_ghost_completion",
              "summarize_selection",
              "explain_control_plane_state",
              "inspect_canvas_snapshot"
            ]
          },
          "context": {
            "$ref": "#/$defs/radishflow_context"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "const": "radish"
          }
        },
        "required": [
          "project"
        ]
      },
      "then": {
        "properties": {
          "task": {
            "enum": [
              "answer_docs_question",
              "summarize_doc_or_thread",
              "suggest_forum_metadata",
              "explain_console_capability",
              "interpret_attachment"
            ]
          },
          "context": {
            "$ref": "#/$defs/radish_context"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "const": "radishflow"
          },
          "task": {
            "const": "suggest_ghost_completion"
          }
        },
        "required": [
          "project",
          "task"
        ]
      },
      "then": {
        "properties": {
          "context": {
            "allOf": [
              {
                "required": [
                  "document_revision",
                  "selected_unit_ids",
                  "legal_candidate_completions"
                ]
              },
              {
                "properties": {
                  "selected_unit_ids": {
                    "minItems": 1,
                    "maxItems": 1
                  }
                }
              },
              {
                "anyOf": [
                  {
                    "required": [
                      "unconnected_ports"
                    ]
                  },
                  {
                    "required": [
                      "missing_canonical_ports"
                    ]
                  }
                ]
              }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "role",
        "name",
        "mime_type"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "json",
            "markdown",
            "text",
            "image",
            "attachment_ref"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "supporting",
            "reference"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "content": {},
        "metadata": {
          "type": "object",
          "default": {}
        }
      },
      "anyOf": [
        {
          "required": [
            "uri"
          ]
        },
        {
          "required": [
            "content"
          ]
        }
      ]
    },
    "tool_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_retrieval",
        "allow_tool_calls",
        "allow_image_reasoning"
      ],
      "properties": {
        "allow_retrieval": {
          "type": "boolean"
        },
        "allow_tool_calls": {
          "type": "boolean"
        },
        "allow_image_reasoning": {
          "type": "boolean"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "requires_confirmation_for_actions"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "advisory"
          ]
        },
        "requires_confirmation_for_actions": {
          "type": "boolean"
        }
      }
    },
    "radishflow_selected_unit": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        }
      }
    },
    "radishflow_nearby_node": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string"
        },
        "distance_px": {
          "type": "number",
          "minimum": 0
        },
        "alignment_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "radishflow_ghost_candidate_completion": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "candidate_ref",
        "ghost_kind",
        "target_port_key"
      ],
      "properties": {
        "candidate_ref": {
          "type": "string",
          "minLength": 1
        },
        "ghost_kind": {
          "type": "string",
          "enum": [
            "ghost_port",
            "ghost_connection",
            "ghost_stream_name"
          ]
        },
        "target_port_key": {
          "type": "string",
          "minLength": 1
        },
        "target_unit_id": {
          "type": "string"
        },
        "source_stream_id": {
          "type": "string"
        },
        "target_node_id": {
          "type": "string"
        },
        "suggested_stream_name": {
          "type": "string"
        },
        "ranking_signals": {
          "$ref": "#/$defs/radishflow_candidate_ranking_signals"
        },
        "naming_signals": {
          "$ref": "#/$defs/radishflow_candidate_naming_signals"
        },
        "conflict_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "is_high_confidence": {
          "type": "boolean"
        },
        "is_tab_default": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "is_tab_default": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "is_high_confidence": {
                "const": true
              },
              "conflict_flags": {
                "maxItems": 0
              }
            },
            "required": [
              "is_high_confidence"
            ]
          }
        }
      ]
    },
    "radishflow_candidate_ranking_signals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "distance_px": {
          "type": "number",
          "minimum": 0
        },
        "alignment_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "topology_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "score_gap_to_next": {
          "type": "number",
          "minimum": 0
        },
        "template_frequency": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "radishflow_candidate_naming_signals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "derived_from_upstream_name": {
          "type": "boolean"
        },
        "applied_prefix": {
          "type": "string",
          "minLength": 1
        },
        "numeric_suffix": {
          "type": "string",
          "minLength": 1
        },
        "reused_existing_pattern": {
          "type": "boolean"
        },
        "collision_checked": {
          "type": "boolean"
        }
      }
    },
    "radishflow_naming_hints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "upstream_stream_names": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "existing_stream_names": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "preferred_outlet_prefix": {
          "type": "string",
          "minLength": 1
        },
        "numeric_suffix_from_unit": {
          "type": "string",
          "minLength": 1
        },
        "preferred_prefix_by_port": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "radishflow_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "document_revision": {
          "type": "integer",
          "minimum": 0
        },
        "selected_unit_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "selected_unit": {
          "$ref": "#/$defs/radishflow_selected_unit"
        },
        "selected_stream_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "diagnostic_summary": {
          "type": "object"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "solve_session": {
          "type": "object"
        },
        "latest_snapshot": {
          "type": "object"
        },
        "unconnected_ports": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "missing_canonical_ports": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "nearby_nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/radishflow_nearby_node"
          }
        },
        "cursor_context": {
          "type": "object",
          "additionalProperties": true
        },
        "legal_candidate_completions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/radishflow_ghost_candidate_completion"
          }
        },
        "naming_hints": {
          "$ref": "#/$defs/radishflow_naming_hints"
        },
        "topology_pattern_hints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "control_plane_state": {
          "type": "object",
          "properties": {
            "entitlement_status": {
              "type": "string"
            },
            "lease_status": {
              "type": "string"
            },
            "sync_status": {
              "type": "string"
            },
            "manifest_status": {
              "type": "string"
            },
            "last_error": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      }
    },
    "radish_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "current_app": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string",
          "minLength": 1
        },
        "resource": {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "slug": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "id": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "viewer": {
          "type": "object",
          "properties": {
            "is_authenticated": {
              "type": "boolean"
            },
            "roles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "permissions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": true
        },
        "attachment_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "search_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
