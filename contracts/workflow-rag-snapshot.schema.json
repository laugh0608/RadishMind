{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-rag-snapshot.schema.json",
  "title": "WorkflowRAGSnapshotV1",
  "description": "Exact immutable application-scoped knowledge snapshot version. List and audit projections must not use this content-bearing shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "snapshot_id", "tenant_ref", "workspace_id", "application_id", "snapshot_key",
    "rag_ref", "snapshot_version", "display_name", "lifecycle_state", "content_classification",
    "profile_ref", "fragment_count", "total_content_bytes", "snapshot_digest", "created_at",
    "created_by_actor_ref", "request_id", "audit_ref", "fragments"
  ],
  "properties": {
    "schema_version": { "const": "workflow_rag_snapshot.v1" },
    "snapshot_id": { "type": "string", "pattern": "^rags_[a-z2-7]{16}$" },
    "tenant_ref": { "$ref": "#/$defs/reference" },
    "workspace_id": { "$ref": "#/$defs/scoped_id" },
    "application_id": { "$ref": "#/$defs/scoped_id" },
    "snapshot_key": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,47}$" },
    "rag_ref": { "type": "string", "pattern": "^workflow\\.rag\\.[a-z][a-z0-9_]{2,47}\\.v[1-9][0-9]*$" },
    "snapshot_version": { "type": "integer", "minimum": 1 },
    "display_name": { "type": "string", "minLength": 2, "maxLength": 120 },
    "lifecycle_state": { "enum": ["active", "archived"] },
    "content_classification": { "enum": ["public", "workspace_internal"] },
    "profile_ref": { "const": "workflow.rag.lexical-ngram-dev.v1" },
    "fragment_count": { "type": "integer", "minimum": 1, "maximum": 256 },
    "total_content_bytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
    "snapshot_digest": { "$ref": "#/$defs/digest" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by_actor_ref": { "$ref": "#/$defs/reference" },
    "request_id": { "$ref": "#/$defs/reference" },
    "audit_ref": { "$ref": "#/$defs/reference" },
    "fragments": {
      "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
      "items": { "$ref": "workflow-rag-fragment.schema.json" }
    }
  },
  "$defs": {
    "reference": { "type": "string", "minLength": 3, "maxLength": 160, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/-]*$" },
    "scoped_id": { "type": "string", "minLength": 3, "maxLength": 120, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
