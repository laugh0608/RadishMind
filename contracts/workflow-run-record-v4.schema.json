{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-run-record-v4.schema.json",
  "title": "WorkflowRunRecordV4",
  "description": "Metadata-only application RAG invocation run. Input, fragments, prompts, answers, provider responses, credentials, and secret material are never persisted.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_version", "run_id", "tenant_ref", "workspace_id", "application_id", "execution_kind", "execution_source_kind", "execution_source_id", "execution_source_version", "status", "failure_code", "failure_summary", "started_at", "completed_at", "input_digest", "input_bytes", "authority", "snapshot", "retrieval_attempt", "answer", "selected_provider", "selected_model", "request_id", "audit_ref", "actor_ref", "side_effects", "diagnostic"],
  "properties": {
    "schema_version": { "const": "workflow_run_record.v4" },
    "record_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "pattern": "^run_[a-z0-9]{16,64}$" },
    "tenant_ref": { "$ref": "#/$defs/ref" },
    "workspace_id": { "$ref": "#/$defs/ref" },
    "application_id": { "$ref": "#/$defs/ref" },
    "execution_kind": { "const": "application_rag_invocation" },
    "execution_source_kind": { "const": "application_configuration_draft" },
    "execution_source_id": { "$ref": "#/$defs/ref" },
    "execution_source_version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["running", "succeeded", "failed", "canceled"] },
    "failure_code": { "oneOf": [{ "type": "null" }, { "type": "string", "pattern": "^workflow_rag_runtime_[a-z_]{3,96}$" }] },
    "failure_summary": { "type": "string", "maxLength": 256 },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "oneOf": [{ "type": "null" }, { "type": "string", "format": "date-time" }] },
    "input_digest": { "$ref": "#/$defs/digest" },
    "input_bytes": { "type": "integer", "minimum": 1, "maximum": 4096 },
    "authority": { "$ref": "#/$defs/authority" },
    "snapshot": { "$ref": "#/$defs/snapshot" },
    "retrieval_attempt": { "$ref": "#/$defs/retrieval" },
    "answer": { "type": "null" },
    "selected_provider": { "$ref": "#/$defs/safe" },
    "selected_model": { "$ref": "#/$defs/safe" },
    "request_id": { "$ref": "#/$defs/ref" },
    "audit_ref": { "$ref": "#/$defs/ref" },
    "actor_ref": { "$ref": "#/$defs/ref" },
    "side_effects": { "$ref": "#/$defs/effects" },
    "diagnostic": { "$ref": "#/$defs/diagnostic" }
  },
  "$defs": {
    "ref": { "type": "string", "minLength": 3, "maxLength": 160, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/-]*$" },
    "safe": { "type": "string", "maxLength": 256, "not": { "pattern": "://" } },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "binding": { "type": "object", "additionalProperties": false, "required": ["binding_id", "binding_version", "binding_digest"], "properties": { "binding_id": { "type": "string", "pattern": "^wragb_[a-z2-7]{16}$" }, "binding_version": { "const": 1 }, "binding_digest": { "$ref": "#/$defs/digest" } } },
    "dataset": { "type": "object", "additionalProperties": false, "required": ["dataset_id", "dataset_version", "dataset_digest"], "properties": { "dataset_id": { "type": "string", "pattern": "^wragd_[a-z2-7]{16}$" }, "dataset_version": { "type": "integer", "minimum": 1 }, "dataset_digest": { "$ref": "#/$defs/digest" } } },
    "snapshot": { "type": "object", "additionalProperties": false, "required": ["snapshot_id", "snapshot_version", "snapshot_digest", "rag_ref"], "properties": { "snapshot_id": { "type": "string", "pattern": "^rags_[a-z2-7]{16}$" }, "snapshot_version": { "type": "integer", "minimum": 1 }, "snapshot_digest": { "$ref": "#/$defs/digest" }, "rag_ref": { "type": "string", "pattern": "^workflow\\.rag\\.[a-z][a-z0-9_]{2,47}\\.v[1-9][0-9]*$" } } },
    "profile": { "type": "object", "additionalProperties": false, "required": ["profile_id", "profile_version", "profile_digest"], "properties": { "profile_id": { "const": "workflow.rag.lexical-ngram-dev.v1" }, "profile_version": { "const": 1 }, "profile_digest": { "$ref": "#/$defs/digest" } } },
    "authority": { "type": "object", "additionalProperties": false, "required": ["assignment_id", "assignment_version", "assignment_digest", "publish_candidate_id", "publish_review_version", "publish_candidate_state", "draft_id", "draft_version", "draft_digest", "binding_ref", "dataset", "candidate_review_id", "baseline_snapshot", "candidate_snapshot", "effective_snapshot_role", "profile", "configured_protocol", "configured_model"], "properties": { "assignment_id": { "type": "string", "pattern": "^wragra_[a-z2-7]{16}$" }, "assignment_version": { "type": "integer", "minimum": 1 }, "assignment_digest": { "$ref": "#/$defs/digest" }, "publish_candidate_id": { "$ref": "#/$defs/ref" }, "publish_review_version": { "type": "integer", "minimum": 1 }, "publish_candidate_state": { "const": "approved" }, "draft_id": { "$ref": "#/$defs/ref" }, "draft_version": { "type": "integer", "minimum": 1 }, "draft_digest": { "$ref": "#/$defs/digest" }, "binding_ref": { "$ref": "#/$defs/binding" }, "dataset": { "$ref": "#/$defs/dataset" }, "candidate_review_id": { "type": "string", "pattern": "^wragr_[a-z2-7]{16}$" }, "baseline_snapshot": { "$ref": "#/$defs/snapshot" }, "candidate_snapshot": { "$ref": "#/$defs/snapshot" }, "effective_snapshot_role": { "const": "candidate" }, "profile": { "$ref": "#/$defs/profile" }, "configured_protocol": { "$ref": "#/$defs/safe" }, "configured_model": { "$ref": "#/$defs/safe" } } },
    "selected": { "type": "object", "additionalProperties": false, "required": ["fragment_ref", "content_digest", "rank", "source_type", "is_official", "excerpt_truncated"], "properties": { "fragment_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" }, "content_digest": { "$ref": "#/$defs/digest" }, "rank": { "type": "integer", "minimum": 1, "maximum": 8 }, "source_type": { "enum": ["document", "wiki", "faq", "forum", "manual"] }, "is_official": { "type": "boolean" }, "excerpt_truncated": { "type": "boolean" } } },
    "retrieval": { "type": "object", "additionalProperties": false, "required": ["node_id", "status", "profile_id", "profile_version", "profile_digest", "query_digest", "query_bytes", "candidate_count", "selected_fragments", "retrieval_latency_ms", "context_bytes", "citation_refs"], "properties": { "node_id": { "$ref": "#/$defs/ref" }, "status": { "enum": ["not_started", "succeeded", "failed"] }, "profile_id": { "const": "workflow.rag.lexical-ngram-dev.v1" }, "profile_version": { "const": 1 }, "profile_digest": { "$ref": "#/$defs/digest" }, "query_digest": { "$ref": "#/$defs/digest" }, "query_bytes": { "type": "integer", "minimum": 0, "maximum": 4096 }, "candidate_count": { "type": "integer", "minimum": 0, "maximum": 256 }, "selected_fragments": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/selected" } }, "retrieval_latency_ms": { "type": "integer", "minimum": 0, "maximum": 2000 }, "context_bytes": { "type": "integer", "minimum": 0, "maximum": 32768 }, "citation_refs": { "type": "array", "maxItems": 8, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" } } } },
    "effects": { "type": "object", "additionalProperties": false, "required": ["retrieval_calls", "provider_calls", "tool_calls", "confirmation_calls", "business_writes", "replay_writes"], "properties": { "retrieval_calls": { "type": "integer", "minimum": 0, "maximum": 1 }, "provider_calls": { "type": "integer", "minimum": 0, "maximum": 1 }, "tool_calls": { "const": 0 }, "confirmation_calls": { "const": 0 }, "business_writes": { "const": 0 }, "replay_writes": { "const": 0 } } },
    "diagnostic": { "type": "object", "additionalProperties": false, "required": ["failure_boundary", "retrieval_failure_category"], "properties": { "failure_boundary": { "enum": ["none", "retrieval_policy", "retrieval_store", "retrieval_rank", "retrieval_context", "retrieval_citation", "provider_selection", "provider_call", "run_store"] }, "retrieval_failure_category": { "enum": ["none", "scope", "snapshot", "profile", "query", "budget", "no_evidence", "provider", "answer", "citation", "store"] } } }
  }
}
