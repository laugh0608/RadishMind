{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/radishflow-export-snapshot.schema.json",
  "title": "RadishFlowExportSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "task",
    "locale"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "string",
      "enum": [
        "explain_diagnostics",
        "suggest_flowsheet_edits",
        "explain_control_plane_state"
      ]
    },
    "locale": {
      "type": "string",
      "minLength": 2
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "document_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "document_revision": {
          "type": "integer",
          "minimum": 0
        },
        "flowsheet_document": {
          "type": "object"
        },
        "flowsheet_document_uri": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selection_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selected_unit_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "selected_stream_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "primary_selected_unit": {
          "type": "object"
        }
      }
    },
    "diagnostics_export": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "diagnostic_summary": {
          "type": "object"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "solve_session_state": {
      "type": "object"
    },
    "solve_snapshot": {
      "type": "object"
    },
    "control_plane_snapshot": {
      "type": "object"
    },
    "support_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/supporting_artifact"
      }
    },
    "tool_hints": {
      "$ref": "#/$defs/tool_hints"
    },
    "safety": {
      "$ref": "#/$defs/safety"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "task": {
            "enum": [
              "explain_diagnostics",
              "suggest_flowsheet_edits"
            ]
          }
        },
        "required": [
          "task"
        ]
      },
      "then": {
        "required": [
          "document_state",
          "selection_state",
          "diagnostics_export"
        ],
        "properties": {
          "document_state": {
            "required": [
              "document_revision"
            ],
            "anyOf": [
              {
                "required": [
                  "flowsheet_document"
                ]
              },
              {
                "required": [
                  "flowsheet_document_uri"
                ]
              }
            ]
          },
          "selection_state": {
            "anyOf": [
              {
                "required": [
                  "selected_unit_ids"
                ]
              },
              {
                "required": [
                  "selected_stream_ids"
                ]
              }
            ]
          },
          "diagnostics_export": {
            "anyOf": [
              {
                "required": [
                  "diagnostic_summary"
                ]
              },
              {
                "required": [
                  "diagnostics"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "explain_control_plane_state"
          }
        },
        "required": [
          "task"
        ]
      },
      "then": {
        "required": [
          "document_state",
          "control_plane_snapshot"
        ],
        "properties": {
          "document_state": {
            "required": [
              "document_revision"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "tool_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_retrieval",
        "allow_tool_calls",
        "allow_image_reasoning"
      ],
      "properties": {
        "allow_retrieval": {
          "type": "boolean"
        },
        "allow_tool_calls": {
          "type": "boolean"
        },
        "allow_image_reasoning": {
          "type": "boolean"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "requires_confirmation_for_actions"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "advisory"
          ]
        },
        "requires_confirmation_for_actions": {
          "type": "boolean"
        }
      }
    },
    "supporting_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "role",
        "name",
        "mime_type"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "json",
            "markdown",
            "text",
            "image",
            "attachment_ref"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "supporting",
            "reference"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "content": {},
        "metadata": {
          "type": "object",
          "default": {}
        }
      },
      "anyOf": [
        {
          "required": [
            "uri"
          ]
        },
        {
          "required": [
            "content"
          ]
        }
      ]
    }
  }
}
