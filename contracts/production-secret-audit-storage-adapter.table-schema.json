{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/production-secret-audit-storage-adapter.table-schema.json",
  "title": "ProductionSecretAuditStorageAdapterLogicalTableSchema",
  "description": "Metadata-only logical table schema artifact for the future production secret audit store storage adapter. It pins logical record fields and contract compatibility without SQL, DDL, physical table names, physical columns, database driver details, schema marker runtime, migration runner or storage adapter runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "table_schema_version",
    "audit_event_ref",
    "audit_event_schema_version",
    "audit_event_kind",
    "storage_adapter_contract_version",
    "storage_adapter_contract_ref",
    "backend_product_evidence_ref",
    "backend_product_class",
    "storage_record_identity_ref",
    "writer_result_ref",
    "idempotency_key_ref",
    "delivery_attempt_ref",
    "append_only_contract_ref",
    "retention_policy_ref",
    "redaction_policy_ref",
    "request_id",
    "audit_ref",
    "policy_version",
    "storage_adapter_result_ref",
    "storage_record_ref",
    "write_status",
    "append_only_sequence_ref",
    "dedupe_decision_ref",
    "delivery_commit_ref",
    "failure_code",
    "failure_boundary",
    "sanitized_diagnostic"
  ],
  "properties": {
    "table_schema_version": {
      "type": "string",
      "const": "audit-storage-adapter-table-schema-v1"
    },
    "audit_event_ref": {
      "$ref": "#/$defs/reference"
    },
    "audit_event_schema_version": {
      "$ref": "#/$defs/version_key"
    },
    "audit_event_kind": {
      "$ref": "#/$defs/version_key"
    },
    "storage_adapter_contract_version": {
      "type": "string",
      "const": "audit-storage-adapter-metadata-contract-v1"
    },
    "storage_adapter_contract_ref": {
      "$ref": "#/$defs/reference"
    },
    "backend_product_evidence_ref": {
      "$ref": "#/$defs/reference"
    },
    "backend_product_class": {
      "type": "string",
      "enum": [
        "managed_database_append_only_table"
      ]
    },
    "storage_record_identity_ref": {
      "$ref": "#/$defs/reference"
    },
    "writer_result_ref": {
      "$ref": "#/$defs/reference"
    },
    "idempotency_key_ref": {
      "$ref": "#/$defs/reference"
    },
    "delivery_attempt_ref": {
      "$ref": "#/$defs/reference"
    },
    "append_only_contract_ref": {
      "$ref": "#/$defs/reference"
    },
    "retention_policy_ref": {
      "$ref": "#/$defs/reference"
    },
    "redaction_policy_ref": {
      "$ref": "#/$defs/reference"
    },
    "request_id": {
      "$ref": "#/$defs/reference"
    },
    "audit_ref": {
      "$ref": "#/$defs/reference"
    },
    "policy_version": {
      "$ref": "#/$defs/version_key"
    },
    "storage_adapter_result_ref": {
      "$ref": "#/$defs/reference"
    },
    "storage_record_ref": {
      "$ref": "#/$defs/reference"
    },
    "write_status": {
      "type": "string",
      "enum": [
        "accepted_metadata_only",
        "rejected_fail_closed"
      ]
    },
    "append_only_sequence_ref": {
      "$ref": "#/$defs/reference"
    },
    "dedupe_decision_ref": {
      "$ref": "#/$defs/reference"
    },
    "delivery_commit_ref": {
      "$ref": "#/$defs/reference"
    },
    "failure_code": {
      "$ref": "#/$defs/version_key"
    },
    "failure_boundary": {
      "$ref": "#/$defs/version_key"
    },
    "sanitized_diagnostic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    }
  },
  "allOf": [
    {
      "not": {
        "required": [
          "secret_value"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_secret"
        ]
      }
    },
    {
      "not": {
        "required": [
          "password"
        ]
      }
    },
    {
      "not": {
        "required": [
          "token"
        ]
      }
    },
    {
      "not": {
        "required": [
          "api_key"
        ]
      }
    },
    {
      "not": {
        "required": [
          "authorization_header"
        ]
      }
    },
    {
      "not": {
        "required": [
          "cookie"
        ]
      }
    },
    {
      "not": {
        "required": [
          "provider_raw_url"
        ]
      }
    },
    {
      "not": {
        "required": [
          "resolver_backend_url"
        ]
      }
    },
    {
      "not": {
        "required": [
          "dsn"
        ]
      }
    },
    {
      "not": {
        "required": [
          "database_hostname"
        ]
      }
    },
    {
      "not": {
        "required": [
          "database_name"
        ]
      }
    },
    {
      "not": {
        "required": [
          "table_name"
        ]
      }
    },
    {
      "not": {
        "required": [
          "column_name"
        ]
      }
    },
    {
      "not": {
        "required": [
          "column_type"
        ]
      }
    },
    {
      "not": {
        "required": [
          "index_name"
        ]
      }
    },
    {
      "not": {
        "required": [
          "constraint_name"
        ]
      }
    },
    {
      "not": {
        "required": [
          "partition_policy"
        ]
      }
    },
    {
      "not": {
        "required": [
          "ddl"
        ]
      }
    },
    {
      "not": {
        "required": [
          "sql"
        ]
      }
    },
    {
      "not": {
        "required": [
          "sql_migration"
        ]
      }
    },
    {
      "not": {
        "required": [
          "database_sequence"
        ]
      }
    },
    {
      "not": {
        "required": [
          "trigger"
        ]
      }
    },
    {
      "not": {
        "required": [
          "database_function"
        ]
      }
    },
    {
      "not": {
        "required": [
          "schema_version_table"
        ]
      }
    },
    {
      "not": {
        "required": [
          "migration_command"
        ]
      }
    },
    {
      "not": {
        "required": [
          "cloud_credential"
        ]
      }
    },
    {
      "not": {
        "required": [
          "credential_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_request_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_response_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_audit_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_event_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_writer_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "raw_storage_payload"
        ]
      }
    },
    {
      "not": {
        "required": [
          "payload_hash"
        ]
      }
    },
    {
      "not": {
        "required": [
          "event_payload_hash"
        ]
      }
    },
    {
      "not": {
        "required": [
          "secret_derived_hash"
        ]
      }
    },
    {
      "not": {
        "required": [
          "provider_error_detail"
        ]
      }
    },
    {
      "not": {
        "required": [
          "database_error_detail"
        ]
      }
    },
    {
      "not": {
        "required": [
          "scanner_raw_finding"
        ]
      }
    },
    {
      "not": {
        "required": [
          "scan_output"
        ]
      }
    },
    {
      "not": {
        "required": [
          "schema_marker_raw_output"
        ]
      }
    },
    {
      "not": {
        "required": [
          "migration_output"
        ]
      }
    }
  ],
  "x-radishmind-logical-schema": {
    "schema_version": "audit-storage-adapter-table-schema-v1",
    "metadata_contract_version": "audit-storage-adapter-metadata-contract-v1",
    "metadata_only": true,
    "backend_product_class": "managed_database_append_only_table",
    "backend_product_profile": "reserved_managed_database_append_only_table_profile",
    "physical_table_details_allowed": false,
    "sql_or_ddl_allowed": false,
    "runtime_created": false,
    "source_statuses": {
      "append_only_table_schema_boundary": "audit_store_storage_adapter_append_only_table_schema_boundary_readiness_defined",
      "metadata_contract_artifact": "audit_store_storage_adapter_metadata_contract_artifact_materialized",
      "table_schema_artifact_materialization": "audit_store_storage_adapter_table_schema_artifact_materialized"
    },
    "logical_field_groups": [
      {
        "id": "identity",
        "source": "append_only_table_schema_boundary_identity_group",
        "logical_fields": [
          "storage_record_ref",
          "storage_record_identity_ref",
          "audit_event_ref",
          "audit_ref",
          "idempotency_key_ref",
          "policy_version"
        ]
      },
      {
        "id": "ordering",
        "source": "append_only_table_schema_boundary_ordering_group",
        "logical_fields": [
          "append_only_sequence_ref",
          "storage_adapter_result_ref",
          "write_status"
        ]
      },
      {
        "id": "payload_reference",
        "source": "append_only_table_schema_boundary_payload_reference_group",
        "logical_fields": [
          "audit_event_schema_version",
          "audit_event_kind",
          "storage_adapter_contract_version",
          "storage_adapter_contract_ref",
          "writer_result_ref",
          "append_only_contract_ref"
        ]
      },
      {
        "id": "retention_redaction",
        "source": "append_only_table_schema_boundary_retention_redaction_group",
        "logical_fields": [
          "retention_policy_ref",
          "redaction_policy_ref"
        ]
      },
      {
        "id": "delivery_recovery",
        "source": "append_only_table_schema_boundary_delivery_recovery_group",
        "logical_fields": [
          "delivery_attempt_ref",
          "delivery_commit_ref",
          "dedupe_decision_ref"
        ]
      },
      {
        "id": "diagnostics",
        "source": "append_only_table_schema_boundary_diagnostics_group",
        "logical_fields": [
          "request_id",
          "backend_product_evidence_ref",
          "backend_product_class",
          "failure_code",
          "failure_boundary",
          "sanitized_diagnostic"
        ]
      }
    ],
    "artifact_guard": {
      "database_product_status": "not_selected",
      "database_vendor_status": "not_selected",
      "database_connection_provider_status": "not_created",
      "sql_migration_status": "not_created",
      "ddl_status": "not_created",
      "schema_marker_runtime_status": "not_created",
      "migration_runner_status": "not_created",
      "storage_adapter_runtime_status": "not_created",
      "audit_store_runtime_status": "not_created",
      "repository_mode_status": "disabled",
      "production_api_status": "not_created"
    }
  },
  "$defs": {
    "reference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_.-]*:[a-zA-Z0-9][a-zA-Z0-9_.:/-]*$"
    },
    "version_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    }
  }
}
