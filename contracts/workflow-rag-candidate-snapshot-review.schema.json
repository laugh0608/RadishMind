{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-rag-candidate-snapshot-review.schema.json",
  "title": "WorkflowRAGCandidateSnapshotReviewV1",
  "description": "Metadata-only comparison of one exact evaluation dataset against baseline and candidate immutable snapshots.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "review_id", "tenant_ref", "workspace_id", "application_id", "dataset", "profile",
    "baseline_snapshot", "candidate_snapshot", "baseline_lifecycle", "candidate_lifecycle", "conclusion",
    "baseline", "candidate", "metric_delta", "samples", "added_finding_codes", "removed_finding_codes",
    "created_at", "created_by_actor_ref", "request_id", "audit_ref"
  ],
  "properties": {
    "schema_version": { "const": "workflow_rag_candidate_snapshot_review.v1" },
    "review_id": { "type": "string", "pattern": "^wragr_[a-z2-7]{16}$" },
    "tenant_ref": { "$ref": "#/$defs/reference" },
    "workspace_id": { "$ref": "#/$defs/scoped_id" },
    "application_id": { "$ref": "#/$defs/scoped_id" },
    "dataset": { "$ref": "#/$defs/dataset_binding" },
    "profile": { "$ref": "#/$defs/profile_binding" },
    "baseline_snapshot": { "$ref": "#/$defs/snapshot_binding" },
    "candidate_snapshot": { "$ref": "#/$defs/snapshot_binding" },
    "baseline_lifecycle": { "enum": ["active", "archived"] },
    "candidate_lifecycle": { "enum": ["active", "archived"] },
    "conclusion": { "enum": ["improved", "unchanged", "regressed", "needs_review"] },
    "baseline": { "$ref": "workflow-rag-quality-review.schema.json" },
    "candidate": { "$ref": "workflow-rag-quality-review.schema.json" },
    "metric_delta": { "$ref": "#/$defs/metric_delta" },
    "samples": { "type": "array", "minItems": 1, "maxItems": 200, "items": { "$ref": "#/$defs/sample_comparison" } },
    "added_finding_codes": { "$ref": "#/$defs/finding_codes" },
    "removed_finding_codes": { "$ref": "#/$defs/finding_codes" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by_actor_ref": { "$ref": "#/$defs/reference" },
    "request_id": { "$ref": "#/$defs/reference" },
    "audit_ref": { "$ref": "#/$defs/reference" }
  },
  "$defs": {
    "reference": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/-]{2,159}$" },
    "scoped_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,119}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "dataset_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["dataset_id", "dataset_version", "dataset_digest"],
      "properties": {
        "dataset_id": { "type": "string", "pattern": "^wragd_[a-z0-9_]{3,47}$" },
        "dataset_version": { "type": "integer", "minimum": 1 },
        "dataset_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "profile_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["profile_id", "profile_version", "profile_digest"],
      "properties": {
        "profile_id": { "const": "workflow.rag.lexical-ngram-dev.v1" },
        "profile_version": { "const": 1 },
        "profile_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "snapshot_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["tenant_ref", "workspace_id", "application_id", "snapshot_id", "snapshot_version", "snapshot_digest", "rag_ref"],
      "properties": {
        "tenant_ref": { "$ref": "#/$defs/reference" },
        "workspace_id": { "$ref": "#/$defs/scoped_id" },
        "application_id": { "$ref": "#/$defs/scoped_id" },
        "snapshot_id": { "type": "string", "pattern": "^rags_[a-z2-7]{16}$" },
        "snapshot_version": { "type": "integer", "minimum": 1 },
        "snapshot_digest": { "$ref": "#/$defs/digest" },
        "rag_ref": { "type": "string", "pattern": "^workflow\\.rag\\.[a-z][a-z0-9_]{2,47}\\.v[1-9][0-9]*$" }
      }
    },
    "metric_delta": {
      "type": "object", "additionalProperties": false,
      "required": ["hit_at_k", "expected_recall_at_k", "required_official_recall_at_k", "mean_reciprocal_rank", "no_evidence_accuracy", "sample_pass_rate"],
      "properties": {
        "hit_at_k": { "type": "number", "minimum": -1, "maximum": 1 },
        "expected_recall_at_k": { "type": "number", "minimum": -1, "maximum": 1 },
        "required_official_recall_at_k": { "type": "number", "minimum": -1, "maximum": 1 },
        "mean_reciprocal_rank": { "type": "number", "minimum": -1, "maximum": 1 },
        "no_evidence_accuracy": { "type": "number", "minimum": -1, "maximum": 1 },
        "sample_pass_rate": { "type": "number", "minimum": -1, "maximum": 1 }
      }
    },
    "sample_comparison": {
      "type": "object", "additionalProperties": false,
      "required": [
        "sample_id", "baseline_passed", "candidate_passed", "baseline_expected_hit_count", "candidate_expected_hit_count",
        "baseline_required_official_hit_count", "candidate_required_official_hit_count", "baseline_first_expected_rank",
        "candidate_first_expected_rank", "change"
      ],
      "properties": {
        "sample_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,47}$" },
        "baseline_passed": { "type": "boolean" },
        "candidate_passed": { "type": "boolean" },
        "baseline_expected_hit_count": { "type": "integer", "minimum": 0 },
        "candidate_expected_hit_count": { "type": "integer", "minimum": 0 },
        "baseline_required_official_hit_count": { "type": "integer", "minimum": 0 },
        "candidate_required_official_hit_count": { "type": "integer", "minimum": 0 },
        "baseline_first_expected_rank": { "type": "integer", "minimum": 0, "maximum": 8 },
        "candidate_first_expected_rank": { "type": "integer", "minimum": 0, "maximum": 8 },
        "change": { "enum": ["improved", "unchanged", "regressed"] }
      }
    },
    "finding_codes": {
      "type": "array", "uniqueItems": true,
      "items": { "enum": ["duplicate_fragment_content", "official_evidence_absent", "fragment_expectation_uncovered", "official_expectation_coverage_partial"] }
    }
  }
}
