{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-rag-quality-review.schema.json",
  "title": "WorkflowRAGQualityReviewV1",
  "description": "Deterministic metadata-only lexical retrieval quality report for one exact evaluation dataset, snapshot and profile binding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "dataset", "snapshot", "profile", "status", "sample_count",
    "thresholds", "metrics", "knowledge_summary", "samples", "findings"
  ],
  "properties": {
    "schema_version": { "const": "workflow_rag_quality_review.v1" },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset_id", "dataset_version", "dataset_digest"],
      "properties": {
        "dataset_id": { "type": "string", "pattern": "^wragd_[a-z0-9_]{3,47}$" },
        "dataset_version": { "type": "integer", "minimum": 1 },
        "dataset_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "snapshot": { "$ref": "#/$defs/snapshot_binding" },
    "profile": { "$ref": "#/$defs/profile_binding" },
    "status": { "enum": ["passed", "needs_review", "failed"] },
    "sample_count": { "type": "integer", "minimum": 1, "maximum": 200 },
    "thresholds": { "$ref": "#/$defs/metrics" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "knowledge_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fragment_count", "official_fragment_count", "expected_fragment_count", "source_type_distribution"],
      "properties": {
        "fragment_count": { "type": "integer", "minimum": 1, "maximum": 256 },
        "official_fragment_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "expected_fragment_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "source_type_distribution": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_type", "count"],
            "properties": {
              "source_type": { "enum": ["document", "wiki", "faq", "forum", "manual"] },
              "count": { "type": "integer", "minimum": 1, "maximum": 256 }
            }
          }
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": { "$ref": "#/$defs/sample_result" }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "fragment_refs"],
        "properties": {
          "code": {
            "enum": [
              "duplicate_fragment_content", "official_evidence_absent",
              "fragment_expectation_uncovered", "official_expectation_coverage_partial"
            ]
          },
          "severity": { "enum": ["review_required", "info"] },
          "fragment_refs": { "$ref": "#/$defs/fragment_refs" }
        }
      }
    }
  },
  "$defs": {
    "sample_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id", "expectation", "query_digest", "query_bytes", "top_k", "failure_code", "selected",
        "expected_ref_count", "expected_hit_count", "required_official_ref_count",
        "required_official_hit_count", "first_expected_rank", "passed"
      ],
      "properties": {
        "sample_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,47}$" },
        "expectation": { "enum": ["evidence_required", "no_evidence"] },
        "query_digest": { "$ref": "#/$defs/digest" },
        "query_bytes": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "top_k": { "type": "integer", "minimum": 1, "maximum": 8 },
        "failure_code": { "type": "string", "pattern": "^(|workflow_rag_[a-z_]{3,80})$" },
        "selected": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fragment_ref", "rank", "content_digest", "source_type", "is_official"],
            "properties": {
              "fragment_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
              "rank": { "type": "integer", "minimum": 1, "maximum": 8 },
              "content_digest": { "$ref": "#/$defs/digest" },
              "source_type": { "enum": ["document", "wiki", "faq", "forum", "manual"] },
              "is_official": { "type": "boolean" }
            }
          }
        },
        "expected_ref_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "expected_hit_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "required_official_ref_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "required_official_hit_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "first_expected_rank": { "type": "integer", "minimum": 0, "maximum": 8 },
        "passed": { "type": "boolean" }
      }
    },
    "snapshot_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_ref", "workspace_id", "application_id", "snapshot_id",
        "snapshot_version", "snapshot_digest", "rag_ref"
      ],
      "properties": {
        "tenant_ref": { "$ref": "#/$defs/reference" },
        "workspace_id": { "$ref": "#/$defs/scoped_id" },
        "application_id": { "$ref": "#/$defs/scoped_id" },
        "snapshot_id": { "type": "string", "pattern": "^rags_[a-z2-7]{16}$" },
        "snapshot_version": { "type": "integer", "minimum": 1 },
        "snapshot_digest": { "$ref": "#/$defs/digest" },
        "rag_ref": { "type": "string", "pattern": "^workflow\\.rag\\.[a-z][a-z0-9_]{2,47}\\.v[1-9][0-9]*$" }
      }
    },
    "profile_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "profile_version", "profile_digest"],
      "properties": {
        "profile_id": { "const": "workflow.rag.lexical-ngram-dev.v1" },
        "profile_version": { "const": 1 },
        "profile_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hit_at_k", "expected_recall_at_k", "required_official_recall_at_k",
        "mean_reciprocal_rank", "no_evidence_accuracy", "sample_pass_rate"
      ],
      "properties": {
        "hit_at_k": { "$ref": "#/$defs/ratio" },
        "expected_recall_at_k": { "$ref": "#/$defs/ratio" },
        "required_official_recall_at_k": { "$ref": "#/$defs/ratio" },
        "mean_reciprocal_rank": { "$ref": "#/$defs/ratio" },
        "no_evidence_accuracy": { "$ref": "#/$defs/ratio" },
        "sample_pass_rate": { "$ref": "#/$defs/ratio" }
      }
    },
    "fragment_refs": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" }
    },
    "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "reference": { "type": "string", "minLength": 3, "maxLength": 160, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/-]*$" },
    "scoped_id": { "type": "string", "minLength": 3, "maxLength": 120, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
