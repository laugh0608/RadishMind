{
  "schema_version": 1,
  "kind": "production_secret_audit_storage_adapter_metadata_contract_v1",
  "contract_id": "production-secret-audit-storage-adapter-metadata-contract-v1",
  "contract_version": "audit-storage-adapter-metadata-contract-v1",
  "status": "metadata_contract_artifact_materialized_static",
  "description": "Metadata-only contract for the future production secret audit store storage adapter. It defines reference-only input/result envelopes, record identity, failure taxonomy and writer compatibility without selecting a backend product or creating runtime.",
  "input_envelope": {
    "required_fields": [
      "audit_event_ref",
      "audit_event_schema_version",
      "audit_event_kind",
      "storage_adapter_contract_version",
      "storage_adapter_contract_ref",
      "backend_product_evidence_ref",
      "backend_product_class",
      "storage_record_identity_ref",
      "writer_result_ref",
      "idempotency_key_ref",
      "delivery_attempt_ref",
      "append_only_contract_ref",
      "retention_policy_ref",
      "redaction_policy_ref",
      "request_id",
      "audit_ref",
      "policy_version"
    ],
    "additional_properties_allowed": false,
    "field_policy": "opaque-reference-and-status-only"
  },
  "result_envelope": {
    "required_fields": [
      "storage_adapter_result_ref",
      "storage_record_ref",
      "storage_record_identity_ref",
      "write_status",
      "append_only_sequence_ref",
      "dedupe_decision_ref",
      "delivery_commit_ref",
      "failure_code",
      "failure_boundary",
      "sanitized_diagnostic",
      "audit_ref",
      "policy_version"
    ],
    "write_status_allowlist": [
      "accepted_metadata_only",
      "rejected_fail_closed"
    ],
    "additional_properties_allowed": false,
    "field_policy": "opaque-reference-and-status-only"
  },
  "record_identity": {
    "required_fields": [
      "storage_record_identity_ref",
      "audit_event_ref",
      "append_only_sequence_ref",
      "idempotency_key_ref",
      "writer_result_ref",
      "policy_version"
    ],
    "identity_policy": "metadata-only stable identity; not a database primary key or provider resource id"
  },
  "writer_compatibility": {
    "writer_output_required_fields": [
      "writer_result_ref",
      "audit_event_ref",
      "audit_event_schema_version",
      "audit_event_kind",
      "idempotency_key_ref",
      "append_only_contract_ref",
      "retention_policy_ref",
      "redaction_policy_ref",
      "policy_version"
    ],
    "storage_adapter_input_fields_consumed_from_writer": [
      "writer_result_ref",
      "audit_event_ref",
      "audit_event_schema_version",
      "audit_event_kind",
      "idempotency_key_ref",
      "append_only_contract_ref",
      "retention_policy_ref",
      "redaction_policy_ref",
      "policy_version"
    ],
    "compatibility_smoke_required": true
  },
  "failure_taxonomy": {
    "families": [
      "dependency_missing",
      "contract_version_mismatch",
      "forbidden_field_detected",
      "record_identity_missing",
      "append_only_reference_missing",
      "retention_redaction_reference_missing",
      "writer_compatibility_missing",
      "runtime_artifact_forbidden"
    ],
    "codes": [
      "audit_store_storage_adapter_metadata_contract_artifact_missing",
      "audit_store_storage_adapter_metadata_contract_required_field_missing",
      "audit_store_storage_adapter_metadata_contract_forbidden_field_allowed",
      "audit_store_storage_adapter_metadata_contract_additional_property_allowed",
      "audit_store_storage_adapter_metadata_contract_writer_compatibility_missing",
      "audit_store_storage_adapter_metadata_contract_secret_material_detected",
      "audit_store_storage_adapter_metadata_contract_runtime_scope_overreach",
      "audit_store_storage_adapter_metadata_contract_backend_product_selection_forbidden"
    ],
    "failure_mode": "fail_closed"
  },
  "forbidden_fields": [
    "secret_value",
    "raw_secret",
    "password",
    "token",
    "api_key",
    "authorization_header",
    "cookie",
    "provider_raw_url",
    "resolver_backend_url",
    "dsn",
    "database_hostname",
    "database_name",
    "table_name",
    "partition_key",
    "bucket_name",
    "queue_name",
    "topic_name",
    "product_endpoint",
    "provider_resource_id",
    "cloud_credential",
    "credential_payload",
    "full_secret_ref",
    "full_credential_handle",
    "raw_request_payload",
    "raw_response_payload",
    "raw_audit_payload",
    "raw_event_payload",
    "raw_writer_payload",
    "raw_storage_payload",
    "payload_hash",
    "secret_derived_hash",
    "provider_error_detail",
    "database_error_detail",
    "scanner_raw_finding",
    "scan_output",
    "recovery_raw_finding",
    "recovery_output"
  ],
  "artifact_guard": {
    "backend_product_selection_status": "not_selected",
    "storage_adapter_runtime_status": "not_created",
    "database_connection_provider_status": "blocked",
    "audit_store_runtime_status": "not_created",
    "repository_mode_status": "disabled",
    "production_api_status": "not_created"
  }
