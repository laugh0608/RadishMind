{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/production-secret-reference.schema.json",
  "title": "RadishMindProductionSecretReferenceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "scope",
    "bindings",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "production_secret_reference_manifest"
    },
    "scope": {
      "type": "string",
      "enum": [
        "secret_reference_only"
      ]
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/secret_reference_binding"
      }
    },
    "policy": {
      "$ref": "#/$defs/policy"
    }
  },
  "$defs": {
    "secret_reference_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment",
        "provider",
        "provider_profile",
        "secret_ref",
        "credential_requirement",
        "secret_ref_status",
        "required_fields",
        "sanitized_fields"
      ],
      "properties": {
        "environment": {
          "type": "string",
          "enum": [
            "test",
            "production"
          ]
        },
        "provider": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]{1,63}$"
        },
        "provider_profile": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]{1,63}$"
        },
        "secret_ref": {
          "type": "string",
          "minLength": 8,
          "maxLength": 160,
          "pattern": "^ref:[a-z0-9][a-z0-9._/-]{6,156}$"
        },
        "credential_requirement": {
          "type": "string",
          "enum": [
            "required",
            "not_required"
          ]
        },
        "secret_ref_status": {
          "type": "string",
          "enum": [
            "present",
            "missing",
            "not_required"
          ]
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "environment",
              "provider",
              "provider_profile",
              "secret_ref",
              "required_fields",
              "sanitized_fields"
            ]
          },
          "uniqueItems": true
        },
        "sanitized_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "credential_state",
              "secret_backend_configured",
              "secret_ref_present",
              "missing_secret_refs",
              "field_sources"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stores_secret_values",
        "resolver_enabled",
        "cloud_calls_allowed",
        "production_secret_backend_ready",
        "forbidden_fields"
      ],
      "properties": {
        "stores_secret_values": {
          "type": "boolean",
          "const": false
        },
        "resolver_enabled": {
          "type": "boolean",
          "const": false
        },
        "cloud_calls_allowed": {
          "type": "boolean",
          "const": false
        },
        "production_secret_backend_ready": {
          "type": "boolean",
          "const": false
        },
        "forbidden_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "api_key",
              "token",
              "cookie",
              "authorization",
              "credential",
              "secret_value",
              "provider_base_url"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
