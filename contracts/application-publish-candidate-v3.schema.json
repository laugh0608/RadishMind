{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/application-publish-candidate-v3.schema.json",
  "title": "ApplicationPublishCandidateV3",
  "description": "复用既有发布审查状态机的 Prompt Application 候选；只保存精确 template ref，不复制源码。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate_id", "workspace_id", "application_id", "draft_id", "draft_version", "draft_digest", "base_application_updated_at", "configuration", "evidence_request_ids", "candidate_state", "review_version", "reviews", "promotion_eligibility", "created_at", "updated_at", "created_by_actor_ref", "updated_by_actor_ref", "request_id", "audit_ref"],
  "properties": {
    "schema_version": {"const": "application_publish_candidate.v3"},
    "candidate_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "workspace_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "application_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/applicationId"},
    "draft_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "draft_version": {"type": "integer", "minimum": 1},
    "draft_digest": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/digest"},
    "base_application_updated_at": {"type": "string", "format": "date-time"},
    "configuration": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/publicConfiguration"},
    "evidence_request_ids": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"}},
    "candidate_state": {"enum": ["pending_review", "approved", "rejected", "changes_requested", "withdrawn"]},
    "review_version": {"type": "integer", "minimum": 0},
    "reviews": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/review"}},
    "promotion_eligibility": {"$ref": "#/$defs/eligibility"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "created_by_actor_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "updated_by_actor_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "request_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "audit_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"}
  },
  "$defs": {
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_version", "decision", "reason", "state", "reviewed_at", "reviewer_ref", "request_id", "audit_ref"],
      "properties": {
        "review_version": {"type": "integer", "minimum": 1},
        "decision": {"enum": ["approve", "reject", "request_changes", "withdraw"]},
        "reason": {"type": "string", "minLength": 4, "maxLength": 500},
        "state": {"enum": ["approved", "rejected", "changes_requested", "withdrawn"]},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "reviewer_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
        "request_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
        "audit_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"}
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "summary"],
      "properties": {
        "code": {"type": "string", "minLength": 1, "maxLength": 160},
        "summary": {"type": "string", "maxLength": 256}
      }
    },
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligible", "status", "blockers"],
      "properties": {
        "eligible": {"type": "boolean"},
        "status": {"enum": ["promotion_blocked", "eligible_for_promotion"]},
        "blockers": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/blocker"}}
      }
    }
  }
}
