{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/radishmind-core-offline-eval-run.schema.json",
  "title": "RadishMindCoreOfflineEvalRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "phase",
    "run_id",
    "created_at",
    "execution",
    "sample_selection",
    "candidate_models",
    "metrics",
    "cost_budget",
    "result_records",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "radishmind_core_offline_eval_run"
    },
    "phase": {
      "type": "string",
      "const": "M4-preparation"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "execution": {
      "$ref": "#/$defs/execution"
    },
    "sample_selection": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sample_group"
      }
    },
    "candidate_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate_model"
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "cost_budget": {
      "$ref": "#/$defs/cost_budget"
    },
    "result_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result_record"
      }
    },
    "decision": {
      "$ref": "#/$defs/decision"
    }
  },
  "$defs": {
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_status",
        "does_not_run_models",
        "provider_access",
        "model_artifacts_downloaded",
        "notes"
      ],
      "properties": {
        "run_status": {
          "type": "string",
          "enum": [
            "planned",
            "completed",
            "blocked"
          ]
        },
        "does_not_run_models": {
          "type": "boolean"
        },
        "provider_access": {
          "type": "string",
          "enum": [
            "none",
            "local_only",
            "remote_provider"
          ]
        },
        "model_artifacts_downloaded": {
          "type": "boolean"
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "sample_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "task",
        "minimum_sample_count",
        "selection_reason",
        "selected_samples"
      ],
      "properties": {
        "project": {
          "type": "string",
          "enum": [
            "radishflow",
            "radish"
          ]
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "minimum_sample_count": {
          "type": "integer",
          "minimum": 1
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        },
        "selected_samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selected_sample"
          }
        }
      }
    },
    "selected_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id",
        "path",
        "coverage_tags"
      ],
      "properties": {
        "sample_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "coverage_tags": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "candidate_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_id",
        "role",
        "target_size",
        "evaluation_role",
        "local_memory_budget_gb"
      ],
      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "student_base",
            "core_candidate",
            "teacher_baseline",
            "lightweight_baseline"
          ]
        },
        "target_size": {
          "type": "string",
          "minLength": 1
        },
        "evaluation_role": {
          "type": "string",
          "minLength": 1
        },
        "local_memory_budget_gb": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "blocking",
        "threshold_by_size"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        },
        "threshold_by_size": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "3B",
            "4B",
            "7B"
          ],
          "properties": {
            "3B": {
              "$ref": "#/$defs/rate"
            },
            "4B": {
              "$ref": "#/$defs/rate"
            },
            "7B": {
              "$ref": "#/$defs/rate"
            }
          }
        }
      }
    },
    "cost_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_local_memory_gb",
        "maximum_local_core_size",
        "excluded_default_sizes",
        "per_candidate"
      ],
      "properties": {
        "target_local_memory_gb": {
          "type": "integer",
          "const": 32
        },
        "maximum_local_core_size": {
          "type": "string",
          "const": "7B"
        },
        "excluded_default_sizes": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "per_candidate": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate_cost_budget"
          }
        }
      }
    },
    "candidate_cost_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_id",
        "run_allowed",
        "max_memory_gb",
        "max_latency_p95_ms",
        "notes"
      ],
      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "run_allowed": {
          "type": "boolean"
        },
        "max_memory_gb": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "max_latency_p95_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "result_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_id",
        "project",
        "task",
        "sample_count",
        "status",
        "metric_results",
        "cost_observation",
        "evidence_paths"
      ],
      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "enum": [
            "radishflow",
            "radish"
          ]
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "completed",
            "blocked",
            "skipped"
          ]
        },
        "metric_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric_result"
          }
        },
        "cost_observation": {
          "$ref": "#/$defs/cost_observation"
        },
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metric_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "threshold",
        "observed_value",
        "passed"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "threshold": {
          "$ref": "#/$defs/rate"
        },
        "observed_value": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "passed": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "cost_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_gb",
        "latency_p95_ms",
        "notes"
      ],
      "properties": {
        "memory_gb": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "latency_p95_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_status",
        "recommended_next_step",
        "requires_human_review",
        "never_promote_when"
      ],
      "properties": {
        "promotion_status": {
          "type": "string",
          "enum": [
            "no_promotion_planned",
            "promote_3b",
            "evaluate_4b",
            "evaluate_7b",
            "blocked"
          ]
        },
        "recommended_next_step": {
          "type": "string",
          "minLength": 1
        },
        "requires_human_review": {
          "type": "boolean"
        },
        "never_promote_when": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
