{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/application-session-turn-v2.schema.json",
  "title": "ApplicationSessionTurnV2",
  "description": "Prompt Application Session 的 metadata-only turn；成功只引用 run v6。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "turn_id", "session_id", "sequence", "client_turn_key", "tenant_ref", "workspace_id", "application_id", "owner_subject_ref", "execution_profile", "authority", "status", "input_digest", "input_bytes", "run_ref", "failure_code", "failure_summary", "started_at", "completed_at", "actor_ref", "request_id", "audit_ref"],
  "properties": {
    "schema_version": {"const": "application_session_turn.v2"},
    "turn_id": {"type": "string", "pattern": "^appturn_[a-z2-7]{16}$"},
    "session_id": {"type": "string", "pattern": "^appsess_[a-z2-7]{16}$"},
    "sequence": {"type": "integer", "minimum": 1},
    "client_turn_key": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "tenant_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "workspace_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "application_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/applicationId"},
    "owner_subject_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "execution_profile": {"const": "prompt_application_invocation_v1"},
    "authority": {"$ref": "application-runtime-authority-v2.schema.json"},
    "status": {"enum": ["running", "succeeded", "failed", "canceled", "outcome_unknown"]},
    "input_digest": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/digest"},
    "input_bytes": {"type": "integer", "minimum": 1, "maximum": 65536},
    "run_ref": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/runRef"}]},
    "failure_code": {"type": "string", "maxLength": 160},
    "failure_summary": {"type": "string", "maxLength": 256},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
    "actor_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "request_id": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"},
    "audit_ref": {"$ref": "application-configuration-draft-v3.schema.json#/$defs/ref"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "running"}}}, "then": {"properties": {"run_ref": {"type": "null"}, "failure_code": {"const": ""}, "failure_summary": {"const": ""}, "completed_at": {"type": "null"}}}},
    {"if": {"properties": {"status": {"const": "succeeded"}}}, "then": {"properties": {"run_ref": {"$ref": "#/$defs/runRef"}, "failure_code": {"const": ""}, "failure_summary": {"const": ""}, "completed_at": {"type": "string", "format": "date-time"}}}},
    {"if": {"properties": {"status": {"enum": ["failed", "canceled", "outcome_unknown"]}}}, "then": {"properties": {"failure_code": {"type": "string", "minLength": 1, "maxLength": 160}, "completed_at": {"type": "string", "format": "date-time"}}}}
  ],
  "$defs": {
    "runRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "schema_version"],
      "properties": {
        "run_id": {"type": "string", "pattern": "^run_[a-z0-9]{16,64}$"},
        "schema_version": {"const": "workflow_run_record.v6"}
      }
    }
  }
}
