{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-definition-release-candidate.schema.json",
  "title": "Workflow Definition Release Candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate_id", "definition_id", "source_draft_id", "source_draft_version", "source_draft_digest", "definition_digest", "snapshot", "activation_eligible", "eligibility_blockers", "state", "review_version", "reviews", "created_at", "updated_at", "created_by_actor_ref", "updated_by_actor_ref", "request_id", "audit_ref"],
  "properties": {
    "schema_version": {"const": "workflow_definition_release_candidate.v1"},
    "candidate_id": {"$ref": "#/$defs/id"},
    "definition_id": {"$ref": "#/$defs/id"},
    "source_draft_id": {"$ref": "#/$defs/id"},
    "source_draft_version": {"type": "integer", "minimum": 1},
    "source_draft_digest": {"$ref": "#/$defs/digest"},
    "definition_digest": {"$ref": "#/$defs/digest"},
    "snapshot": {"$ref": "#/$defs/snapshot"},
    "activation_eligible": {"type": "boolean"},
    "eligibility_blockers": {"type": "array", "maxItems": 100, "items": {"type": "string", "minLength": 1, "maxLength": 240}},
    "state": {"enum": ["pending", "approved", "rejected", "superseded"]},
    "review_version": {"type": "integer", "minimum": 0},
    "reviews": {"type": "array", "maxItems": 100, "items": {"$ref": "workflow-definition-release-decision.schema.json"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "created_by_actor_ref": {"type": "string", "minLength": 1, "maxLength": 240},
    "updated_by_actor_ref": {"type": "string", "minLength": 1, "maxLength": 240},
    "request_id": {"type": "string", "minLength": 1, "maxLength": 240},
    "audit_ref": {"type": "string", "minLength": 1, "maxLength": 240}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,159}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "string_list": {"type": "array", "maxItems": 200, "items": {"type": "string", "maxLength": 4000}},
    "contract": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_id", "required_fields", "summary"],
      "properties": {"contract_id": {"type": "string", "maxLength": 160}, "required_fields": {"$ref": "#/$defs/string_list"}, "summary": {"type": "string", "maxLength": 4000}}
    },
    "node": {
      "type": "object", "additionalProperties": false,
      "required": ["node_id", "node_type", "label", "input_summary", "output_summary", "input_contract_ref", "output_contract_ref", "input_contract_fields", "output_contract_fields", "output_mapping_summary", "provider_ref", "tool_ref", "rag_ref", "risk_level", "requires_confirmation"],
      "properties": {
        "node_id": {"$ref": "#/$defs/id"}, "node_type": {"enum": ["prompt", "llm", "condition", "output"]}, "label": {"type": "string", "maxLength": 160},
        "input_summary": {"type": "string", "maxLength": 4000}, "output_summary": {"type": "string", "maxLength": 4000},
        "input_contract_ref": {"type": "string", "maxLength": 160}, "output_contract_ref": {"type": "string", "maxLength": 160},
        "input_contract_fields": {"$ref": "#/$defs/string_list"}, "output_contract_fields": {"$ref": "#/$defs/string_list"},
        "output_mapping_summary": {"type": "string", "maxLength": 4000}, "provider_ref": {"type": "string", "maxLength": 160},
        "tool_ref": {"type": "string", "maxLength": 160}, "rag_ref": {"type": "string", "maxLength": 160}, "risk_level": {"type": "string", "maxLength": 80},
        "requires_confirmation": {"type": "boolean"}
      }
    },
    "edge": {
      "type": "object", "additionalProperties": false,
      "required": ["edge_id", "from_node_id", "to_node_id", "condition_summary"],
      "properties": {"edge_id": {"$ref": "#/$defs/id"}, "from_node_id": {"$ref": "#/$defs/id"}, "to_node_id": {"$ref": "#/$defs/id"}, "condition_summary": {"type": "string", "maxLength": 4000}}
    },
    "snapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "name", "description", "nodes", "edges", "input_contract", "output_contract", "provider_refs", "tool_refs", "rag_refs", "requested_capabilities", "execution_profile"],
      "properties": {
        "schema_version": {"const": "saved_workflow_draft.v1"}, "name": {"type": "string", "minLength": 1, "maxLength": 4000}, "description": {"type": "string", "maxLength": 4000},
        "nodes": {"type": "array", "minItems": 1, "maxItems": 50, "items": {"$ref": "#/$defs/node"}}, "edges": {"type": "array", "maxItems": 120, "items": {"$ref": "#/$defs/edge"}},
        "input_contract": {"$ref": "#/$defs/contract"}, "output_contract": {"$ref": "#/$defs/contract"},
        "provider_refs": {"$ref": "#/$defs/string_list"}, "tool_refs": {"$ref": "#/$defs/string_list"}, "rag_refs": {"$ref": "#/$defs/string_list"}, "requested_capabilities": {"$ref": "#/$defs/string_list"},
        "execution_profile": {"const": "workflow_definition_executor_v1"}
      }
    }
  }
}
