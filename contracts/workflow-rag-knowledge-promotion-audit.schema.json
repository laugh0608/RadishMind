{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-rag-knowledge-promotion-audit.schema.json",
  "title": "WorkflowRAGKnowledgePromotionAuditV1",
  "description": "Append-only metadata audit for candidate creation, human decisions and immutable binding issuance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_id", "event_kind", "candidate_id", "candidate_digest", "candidate_state", "record_version",
    "binding_ref", "tenant_ref", "workspace_id", "application_id", "owner_subject_ref", "actor_ref", "occurred_at",
    "request_id", "audit_ref"
  ],
  "properties": {
    "schema_version": { "const": "workflow_rag_knowledge_promotion_audit.v1" },
    "event_id": { "type": "string", "pattern": "^wragpa_[a-z2-7]{16}$" },
    "event_kind": { "type": "string", "pattern": "^promotion_(candidate_created|binding_issued|decision_(approve|reject|defer|cancel))$" },
    "candidate_id": { "type": "string", "pattern": "^wragp_[a-z2-7]{16}$" },
    "candidate_digest": { "$ref": "#/$defs/digest" },
    "candidate_state": { "enum": ["pending", "deferred", "approved", "rejected", "canceled"] },
    "record_version": { "type": "integer", "minimum": 1 },
    "binding_ref": {
      "oneOf": [
        { "$ref": "workflow-rag-knowledge-promotion-candidate.schema.json#/$defs/binding_ref" },
        { "type": "null" }
      ]
    },
    "tenant_ref": { "$ref": "#/$defs/reference" },
    "workspace_id": { "$ref": "#/$defs/scoped_id" },
    "application_id": { "$ref": "#/$defs/scoped_id" },
    "owner_subject_ref": { "$ref": "#/$defs/reference" },
    "actor_ref": { "$ref": "#/$defs/reference" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "request_id": { "$ref": "#/$defs/reference" },
    "audit_ref": { "$ref": "#/$defs/reference" }
  },
  "$defs": {
    "reference": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/-]{2,159}$" },
    "scoped_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,119}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
