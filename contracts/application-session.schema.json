{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/application-session.schema.json",
  "title": "Application Session v1",
  "description": "Metadata-only user-workspace interaction session. It never stores transcript, input, answer, prompt, provider response, credential, token, or header material.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "tenant_ref", "workspace_id", "application_id", "owner_subject_ref", "state", "record_version", "profile_binding", "authority", "content_retention", "turn_count", "last_turn_id", "created_at", "updated_at", "closed_at", "created_by_actor_ref", "updated_by_actor_ref", "request_id", "audit_ref"],
  "properties": {
    "schema_version": {"const": "application_session.v1"},
    "session_id": {"type": "string", "pattern": "^appsess_[a-z2-7]{16}$"},
    "tenant_ref": {"$ref": "#/$defs/ref"},
    "workspace_id": {"$ref": "#/$defs/ref"},
    "application_id": {"$ref": "#/$defs/ref"},
    "owner_subject_ref": {"$ref": "#/$defs/ref"},
    "state": {"enum": ["active", "closed"]},
    "record_version": {"type": "integer", "minimum": 1},
    "profile_binding": {"$ref": "#/$defs/profile_binding"},
    "authority": {"$ref": "application-runtime-authority.schema.json"},
    "content_retention": {"const": "metadata_only"},
    "turn_count": {"type": "integer", "minimum": 0},
    "last_turn_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^appturn_[a-z2-7]{16}$"}]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "closed_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
    "created_by_actor_ref": {"$ref": "#/$defs/ref"},
    "updated_by_actor_ref": {"$ref": "#/$defs/ref"},
    "request_id": {"$ref": "#/$defs/ref"},
    "audit_ref": {"$ref": "#/$defs/ref"}
  },
  "allOf": [
    {"if": {"properties": {"state": {"const": "active"}}}, "then": {"properties": {"closed_at": {"type": "null"}}}},
    {"if": {"properties": {"state": {"const": "closed"}}}, "then": {"properties": {"closed_at": {"type": "string", "format": "date-time"}}}}
  ],
  "$defs": {
    "ref": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"},
    "profile_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_profile"],
      "properties": {"execution_profile": {"enum": ["workflow_definition_executor_v1", "application_rag_invocation_v1"]}, "definition_id": {"$ref": "#/$defs/ref"}},
      "allOf": [
        {"if": {"properties": {"execution_profile": {"const": "workflow_definition_executor_v1"}}}, "then": {"required": ["definition_id"]}},
        {"if": {"properties": {"execution_profile": {"const": "application_rag_invocation_v1"}}}, "then": {"not": {"required": ["definition_id"]}}}
      ]
    }
  }
}
