{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-rag-application-answer.schema.json",
  "title": "WorkflowRAGApplicationAnswerV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "answer", "citations", "limitations", "confidence"],
  "properties": {
    "schema_version": { "const": "workflow_rag_application_answer.v1" },
    "answer": { "type": "string", "minLength": 1, "maxLength": 16384 },
    "citations": { "type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": { "type": "object", "additionalProperties": false, "required": ["fragment_ref", "claim_summary"], "properties": { "fragment_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" }, "claim_summary": { "type": "string", "minLength": 1, "maxLength": 512 } } } },
    "limitations": { "type": "array", "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 512 } },
    "confidence": { "enum": ["low", "medium", "high"] }
  }
}
