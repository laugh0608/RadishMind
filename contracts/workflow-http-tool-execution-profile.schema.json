{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/contracts/workflow-http-tool-execution-profile.schema.json",
  "title": "WorkflowHttpToolExecutionProfileV1",
  "description": "Environment-owned execution profile for one fixed HTTPS GET target. This contract is never exposed as an action-plan projection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "profile_version",
    "tool_id",
    "definition_digest",
    "environment",
    "enabled",
    "method",
    "target_policy_key",
    "target_policy",
    "credential_policy",
    "timeout_ms",
    "max_response_bytes",
    "max_output_bytes",
    "max_attempts",
    "network_policy",
    "test_only_loopback",
    "audit_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "workflow_http_tool_execution_profile.v1"
    },
    "profile_id": {
      "type": "string",
      "pattern": "^workflow_http_profile_[a-z0-9_]{1,80}$"
    },
    "profile_version": {
      "type": "integer",
      "minimum": 1
    },
    "tool_id": {
      "$ref": "#/$defs/tool_id"
    },
    "definition_digest": {
      "$ref": "#/$defs/digest"
    },
    "environment": {
      "enum": [
        "development",
        "test"
      ]
    },
    "enabled": {
      "type": "boolean"
    },
    "method": {
      "const": "GET"
    },
    "target_policy_key": {
      "$ref": "#/$defs/policy_key"
    },
    "target_policy": {
      "$ref": "#/$defs/target_policy"
    },
    "credential_policy": {
      "const": "none"
    },
    "timeout_ms": {
      "type": "integer",
      "const": 5000
    },
    "max_response_bytes": {
      "type": "integer",
      "const": 65536
    },
    "max_output_bytes": {
      "type": "integer",
      "const": 16384
    },
    "max_attempts": {
      "type": "integer",
      "const": 1
    },
    "network_policy": {
      "$ref": "#/$defs/network_policy"
    },
    "test_only_loopback": {
      "type": "boolean"
    },
    "audit_ref": {
      "$ref": "#/$defs/reference"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "test_only_loopback": {
            "const": true
          }
        },
        "required": [
          "test_only_loopback"
        ]
      },
      "then": {
        "properties": {
          "environment": {
            "const": "test"
          }
        }
      }
    }
  ],
  "$defs": {
    "tool_id": {
      "type": "string",
      "pattern": "^workflow\\.http\\.[a-z0-9][a-z0-9._-]*\\.v[0-9]+$",
      "maxLength": 120
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "reference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/-]*$"
    },
    "policy_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{2,79}$"
    },
    "target_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "host",
        "port",
        "path",
        "query_mappings"
      ],
      "properties": {
        "scheme": {
          "const": "https"
        },
        "host": {
          "type": "string",
          "format": "hostname",
          "maxLength": 253
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "path": {
          "type": "string",
          "pattern": "^/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*$",
          "maxLength": 512
        },
        "query_mappings": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "argument_key",
              "query_key"
            ],
            "properties": {
              "argument_key": {
                "enum": [
                  "resource_key",
                  "locale"
                ]
              },
              "query_key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]{0,63}$"
              }
            }
          }
        }
      }
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "follow_redirects",
        "use_ambient_proxy",
        "automatic_retry",
        "fallback_enabled",
        "cross_profile_connection_reuse",
        "require_all_resolved_addresses_public",
        "pin_validated_address",
        "preserve_tls_server_name"
      ],
      "properties": {
        "follow_redirects": {
          "const": false
        },
        "use_ambient_proxy": {
          "const": false
        },
        "automatic_retry": {
          "const": false
        },
        "fallback_enabled": {
          "const": false
        },
        "cross_profile_connection_reuse": {
          "const": false
        },
        "require_all_resolved_addresses_public": {
          "const": true
        },
        "pin_validated_address": {
          "const": true
        },
        "preserve_tls_server_name": {
          "const": true
        }
      }
    }
  }
}
