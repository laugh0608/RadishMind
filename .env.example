RADISHMIND_MODEL_PROFILE=anyrouter
RADISHMIND_MODEL_API_STYLE=openai-compatible
RADISHMIND_MODEL_REQUEST_TIMEOUT_SECONDS=120

# Preferred real-provider profile.
RADISHMIND_MODEL_PROFILE_ANYROUTER_API_STYLE=openai-compatible
RADISHMIND_MODEL_PROFILE_ANYROUTER_BASE_URL=https://anyrouter.top/v1
RADISHMIND_MODEL_PROFILE_ANYROUTER_NAME=gemini-2.5-pro
RADISHMIND_MODEL_PROFILE_ANYROUTER_API_KEY=replace-with-your-anyrouter-api-key

# GPT-5 mirror profiles.
RADISHMIND_MODEL_PROFILE_SUB_JLYPX_API_STYLE=openai-compatible
RADISHMIND_MODEL_PROFILE_SUB_JLYPX_BASE_URL=https://sub.jlypx.de/v1
RADISHMIND_MODEL_PROFILE_SUB_JLYPX_NAME=gpt-5
RADISHMIND_MODEL_PROFILE_SUB_JLYPX_API_KEY=replace-with-your-sub-jlypx-api-key

RADISHMIND_MODEL_PROFILE_QAQ_API_STYLE=openai-compatible
RADISHMIND_MODEL_PROFILE_QAQ_BASE_URL=https://ai.qaq.al/v1
RADISHMIND_MODEL_PROFILE_QAQ_NAME=gpt-5
RADISHMIND_MODEL_PROFILE_QAQ_API_KEY=replace-with-your-qaq-api-key

# Native Google Gemini profile.
RADISHMIND_MODEL_PROFILE_GOOGLE_GEMINI_API_STYLE=gemini-native
RADISHMIND_MODEL_PROFILE_GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
RADISHMIND_MODEL_PROFILE_GOOGLE_GEMINI_NAME=gemini-2.5-pro
RADISHMIND_MODEL_PROFILE_GOOGLE_GEMINI_API_KEY=replace-with-your-google-gemini-api-key
RADISHMIND_MODEL_NAME_ALT_GOOGLE_GEMINI_FLASH=gemini-2.5-flash
RADISHMIND_MODEL_NAME_ALT_GOOGLE_GEMINI_PRO=gemini-2.5-pro

# Legacy fallback profile retained for historical replay or temporary provider instability.
RADISHMIND_MODEL_PROFILE_DEEPSEEK_API_STYLE=openai-compatible
RADISHMIND_MODEL_PROFILE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
RADISHMIND_MODEL_PROFILE_DEEPSEEK_NAME=deepseek-chat
RADISHMIND_MODEL_PROFILE_DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
RADISHMIND_MODEL_NAME_ALT_DEEPSEEK_REASONER=deepseek-reasoner

# Paused by default. Keep only if you still need historical openrouter replay locally.
RADISHMIND_MODEL_PROFILE_OPENROUTER_API_STYLE=openai-compatible
RADISHMIND_MODEL_PROFILE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RADISHMIND_MODEL_PROFILE_OPENROUTER_NAME=qwen/qwen3.6-plus
RADISHMIND_MODEL_PROFILE_OPENROUTER_API_KEY=replace-with-your-openrouter-api-key

# Backward-compatible single-profile keys. Existing local setups may continue using these.
RADISHMIND_MODEL_BASE_URL=https://anyrouter.top/v1
RADISHMIND_MODEL_NAME=gemini-2.5-pro
RADISHMIND_MODEL_API_KEY=replace-with-your-anyrouter-api-key

# Local reference models for manual switching.
RADISHMIND_MODEL_NAME_ALT_NEMOTRON=nvidia/nemotron-nano-12b-v2-vl:free
RADISHMIND_MODEL_NAME_ALT_GEMMA=google/gemma-3-27b-it:free
RADISHMIND_MODEL_NAME_ALT_GEMMA4_31B=google/gemma-4-31b-it:free
RADISHMIND_MODEL_NAME_ALT_NEMOTRON3_SUPER=nvidia/nemotron-3-super-120b-a12b:free
RADISHMIND_MODEL_NAME_ALT_GEMMA4_26B=google/gemma-4-26b-a4b-it:free
