RADISHMIND_COMPOSE_PROJECT_NAME=radishmind

RADISHMIND_IMAGE_REGISTRY=ghcr.io/laugh0608/radishmind
RADISHMIND_IMAGE_TRACK=test
RADISHMIND_IMAGE_TAG=

RADISHMIND_PUBLIC_BASE_URL=https://radishmind-test.example.invalid
RADISHMIND_SECRET_SOURCE=external-required-before-production

RADISHMIND_PLATFORM_HTTP_BIND=127.0.0.1
RADISHMIND_PLATFORM_HTTP_PORT=7000
RADISHMIND_PLATFORM_PROVIDER=
RADISHMIND_PLATFORM_PROVIDER_PROFILE=
RADISHMIND_PLATFORM_MODEL=
RADISHMIND_PLATFORM_BASE_URL=
RADISHMIND_PLATFORM_BRIDGE_TIMEOUT=30s
RADISHMIND_PLATFORM_READ_HEADER_TIMEOUT=5s
RADISHMIND_PLATFORM_WRITE_TIMEOUT=30s
RADISHMIND_PLATFORM_TEMPERATURE=0
RADISHMIND_PLATFORM_HEALTH_INTERVAL=10s
RADISHMIND_PLATFORM_HEALTH_TIMEOUT=5s
RADISHMIND_PLATFORM_HEALTH_RETRIES=10

RADISHMIND_CONSOLE_HTTP_BIND=127.0.0.1
RADISHMIND_CONSOLE_HTTP_PORT=4000
RADISHMIND_CONSOLE_HEALTH_INTERVAL=10s
RADISHMIND_CONSOLE_HEALTH_TIMEOUT=5s
RADISHMIND_CONSOLE_HEALTH_RETRIES=10
