{
  "schema_version": 1,
  "kind": "copilot_training_dataset_governance_manifest",
  "dataset_id": "copilot-training-dataset-governance-v0",
  "status": "draft",
  "created_for": "teacher-student-distillation",
  "scope": {
    "projects": [
      "radishflow",
      "radish"
    ],
    "tasks": [
      "suggest_flowsheet_edits",
      "suggest_ghost_completion",
      "answer_docs_question"
    ],
    "training_sample_contract": "contracts/copilot-training-sample.schema.json",
    "conversion_entrypoint": "scripts/build-copilot-training-samples.py"
  },
  "source_conversion_manifests": [
    {
      "source": "golden_response",
      "manifest": "scripts/checks/fixtures/copilot-training-sample-conversion-manifest.json",
      "summary": "scripts/checks/fixtures/copilot-training-sample-conversion-summary.json",
      "current_sample_count": 9,
      "role": "small_seed_set"
    },
    {
      "source": "teacher_capture",
      "manifest": "scripts/checks/fixtures/copilot-training-sample-candidate-record-conversion-manifest.json",
      "summary": "scripts/checks/fixtures/copilot-training-sample-candidate-record-conversion-summary.json",
      "current_sample_count": 9,
      "role": "audited_teacher_seed_set"
    }
  ],
  "candidate_record_eligibility": {
    "may_enter_training_set_when_all_true": [
      "record_is_explicitly_listed_in_a_training_conversion_manifest",
      "batch_manifest_exists_and_matches_project_task",
      "audit_report_exists_and_points_to_batch_manifest",
      "selected_sample_status_is_pass",
      "candidate_record_schema_validated",
      "embedded_copilot_response_schema_validated",
      "record_project_task_sample_id_match_committed_eval_sample",
      "source_eval_sample_is_committed",
      "risk_and_confirmation_boundaries_are_preserved",
      "citation_ids_resolve_within_target_response",
      "teacher_provider_model_and_record_id_are_traceable"
    ],
    "must_not_enter_training_set_when_any_true": [
      "audit_status_failed_or_missing",
      "schema_invalid_record_or_response",
      "citation_or_source_drift_not_reviewed",
      "requires_confirmation_weakened_or_removed",
      "high_risk_action_without_requires_confirmation",
      "provider_raw_dump_without_committed_candidate_record",
      "record_from_uncommitted_or_external_batch",
      "duplicate_semantic_sample_without_dedup_reason",
      "manual_review_status_rejected_or_deprecated"
    ]
  },
  "sampling_policy": {
    "strategy": "stratified_manual_review_before_large_jsonl_generation",
    "strata": [
      "project",
      "task",
      "source",
      "provider",
      "model",
      "risk_level",
      "requires_confirmation",
      "coverage_tags",
      "batch_id"
    ],
    "current_seed_set_review": {
      "manual_review_ratio": 1.0,
      "reason": "The current committed seed set is intentionally small and should stay fully reviewable."
    },
    "larger_candidate_record_pool_review": {
      "default_manual_review_ratio": 0.2,
      "minimum_reviewed_records_per_stratum": 5,
      "rounding": "ceil",
      "full_review_required_for": [
        "new_project_or_task",
        "new_provider_or_model",
        "high_risk_actions",
        "requires_confirmation_true",
        "new_patch_shape_or_action_kind",
        "new_retrieval_source_family",
        "new_image_or_artifact_contract",
        "previously_failed_or_regressed_pattern",
        "schema_or_contract_version_change"
      ],
      "holdout_policy": {
        "offline_eval_holdout_ratio": 0.1,
        "minimum_holdout_records_per_task": 3,
        "rule": "Holdout samples selected for offline eval must not be duplicated into the same training JSONL split."
      }
    }
  },
  "manual_review": {
    "states": [
      "not_required_seed_fixture",
      "pending_review",
      "sampled_for_review",
      "reviewed_pass",
      "reviewed_changes_required",
      "rejected",
      "deprecated"
    ],
    "required_review_dimensions": [
      "schema_validity",
      "task_relevance",
      "citation_alignment",
      "risk_level_correctness",
      "requires_confirmation_preservation",
      "advisory_only_boundary",
      "duplicate_or_near_duplicate_check",
      "source_traceability",
      "offline_eval_holdout_leakage"
    ],
    "review_record_expectation": "Future review records may be committed as small JSON or Markdown summaries under training/datasets/; large generated JSONL stays under tmp/ by default."
  },
  "quality_gates": {
    "required_before_jsonl_generation": [
      "conversion_manifest_reviewed",
      "source_records_are_committed",
      "source_summaries_match_regenerated_conversion",
      "copilot_training_sample_schema_validated",
      "nested_copilot_request_schema_validated",
      "nested_copilot_response_schema_validated",
      "risk_reviewed",
      "citation_checked",
      "manual_review_requirement_resolved"
    ],
    "required_before_training_run": [
      "offline_eval_holdout_declared",
      "no_committed_large_jsonl",
      "no_model_weight_or_checkpoint_artifacts",
      "no_provider_raw_dump",
      "training_command_recorded_without_starting_model_download"
    ]
  },
  "exit_conditions": [
    "A source batch audit result changes from pass to failed.",
    "A schema or contract change makes the generated CopilotTrainingSample invalid.",
    "Manual review marks the sample rejected or deprecated.",
    "The sample weakens advisory-only or requires_confirmation boundaries.",
    "Citation, retrieval source, or record provenance can no longer be traced.",
    "The sample is found to duplicate an existing training example without a documented coverage reason.",
    "The sample causes offline eval leakage by appearing in both train and held-out eval split.",
    "A later governance report identifies the pattern as obsolete or harmful for the current task contract."
  ],
  "artifact_policy": {
    "committed_allowed": [
      "manifest",
      "summary",
      "review_record",
      "small_fixture_with_explicit_retirement_condition"
    ],
    "committed_disallowed": [
      "large_jsonl",
      "model_weights",
      "checkpoint",
      "adapter_binary",
      "provider_raw_dump",
      "downloaded_model_cache"
    ],
    "default_generated_jsonl_location": "tmp/"
  },
  "offline_eval_connection": {
    "eval_run_contract": "contracts/radishmind-core-offline-eval-run.schema.json",
    "planned_eval_fixture": "scripts/checks/fixtures/radishmind-core-offline-eval-run-basic.json",
    "connection_rule": "Training collection manifests must preserve a held-out eval split and must not overwrite observed offline metrics before real model evaluation is executed."
  }
}
