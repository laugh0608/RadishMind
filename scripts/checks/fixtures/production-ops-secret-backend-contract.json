      "credential_state",
      "secret_backend_configured",
      "secret_ref_present",
      "missing_secret_refs",
      "field_sources"
    ],
    "forbidden_outputs": [
      "api key value",
      "token value",
      "cookie value",
      "authorization header value",
      "provider base URL value",
      "cloud secret payload"
    ]
  },
