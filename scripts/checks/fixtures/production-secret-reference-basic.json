{
  "schema_version": 1,
  "kind": "production_secret_reference_manifest",
  "scope": "secret_reference_only",
  "bindings": [
    {
      "environment": "test",
      "provider": "openai-compatible",
      "provider_profile": "default",
      "secret_ref": "ref:radishmind/test/openai-compatible/default-api-key",
      "credential_requirement": "required",
      "secret_ref_status": "present",
      "required_fields": [
        "environment",
        "provider",
        "provider_profile",
        "secret_ref",
        "required_fields",
        "sanitized_fields"
      ],
      "sanitized_fields": [
        "credential_state",
        "secret_backend_configured",
        "secret_ref_present",
        "missing_secret_refs",
        "field_sources"
      ]
    },
    {
      "environment": "production",
      "provider": "openai-compatible",
      "provider_profile": "default",
      "secret_ref": "ref:radishmind/production/openai-compatible/default-api-key",
      "credential_requirement": "required",
      "secret_ref_status": "present",
      "required_fields": [
        "environment",
        "provider",
        "provider_profile",
        "secret_ref",
        "required_fields",
        "sanitized_fields"
      ],
      "sanitized_fields": [
        "credential_state",
        "secret_backend_configured",
        "secret_ref_present",
        "missing_secret_refs",
        "field_sources"
      ]
    }
  ],
  "policy": {
    "stores_secret_values": false,
    "resolver_enabled": false,
    "cloud_calls_allowed": false,
    "production_secret_backend_ready": false,
    "forbidden_fields": [
      "api_key",
      "token",
      "cookie",
      "authorization",
      "credential",
      "secret_value",
      "provider_base_url"
    ]
  }
}
