    {
      "term_id": "dev-only",
      "preferred_zh": "仅开发",
      "usage_boundary": "环境边界正文写中文，配置键和专题名保留原文"
    },
    {
      "term_id": "scope",
      "preferred_zh": "作用域",
      "usage_boundary": "协议字段和类型名保留原文，正文说明用中文"
    },
    {
      "term_id": "owner",
      "preferred_zh": "所有者",
      "usage_boundary": "字段名保留原文，正文说明用中文"
