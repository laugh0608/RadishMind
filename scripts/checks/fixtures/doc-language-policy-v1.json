    {
      "term_id": "metadata-only",
      "preferred_zh": "仅元数据",
      "usage_boundary": "决策边界正文写中文，状态锚点和文件名保留原文"
    },
    {
      "term_id": "fail-closed",
      "preferred_zh": "失败关闭",
      "usage_boundary": "失败语义正文写中文，fixture ID 保留原文"
