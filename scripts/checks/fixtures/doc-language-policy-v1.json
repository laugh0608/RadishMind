    {
      "term_id": "baseline",
      "preferred_zh": "基线",
      "usage_boundary": "字段名和状态锚点保留原文，正文说明用中文"
    },
    {
      "term_id": "drift",
      "preferred_zh": "漂移",
      "usage_boundary": "错误码和字段名保留原文，正文说明用中文"
    },
    {
      "term_id": "offline",
      "preferred_zh": "离线",
      "usage_boundary": "状态值保留原文，正文说明用中文"
