    "future_owner_source": "Radish OIDC subject or team ownership policy",
    "required_owner_fields_before_repository_adapter": [
      "owner_subject_ref",
      "created_by_actor_ref",
      "updated_by_actor_ref",
      "tenant_ref",
      "workspace_id",
      "application_id"
    ],
    "workspace_membership_check_required_before_repository_adapter": true,
    "tenant_predicate_required_before_repository_adapter": true,
    "owner_grants_cross_workspace_access": false,
    "team_sharing_defined_in_this_slice": false,
    "radish_oidc_claim_mapping_satisfied": false
  },
  "version_conflict_policy": {
    "status": "optimistic_concurrency_required",
    "client_field": "expected_draft_version",
    "server_field": "draft_version",
    "failure_code": "draft_version_conflict",
    "overwrite_on_conflict_allowed": false,
    "local_draft_retained_on_conflict": true,
    "sample_fallback_allowed": false,
    "required_response_metadata": [
      "current_draft_version",
      "current_updated_at",
      "current_updated_by_actor_ref",
      "request_id",
      "audit_ref"
    ]
  },
  "no_sample_fallback_policy": {
    "status": "fail_closed_required",
    "sample_or_fixture_may_be_displayed_only_as": [
      "sample",
      "unsaved_local"
    ],
    "failure_codes": [
      "draft_scope_denied",
      "draft_not_found",
      "draft_schema_version_unsupported",
      "draft_version_conflict",
      "draft_store_unavailable",
      "draft_write_disabled",
      "repository_store_disabled",
      "invalid_draft_store_mode",
      "draft_store_contract_mismatch"
    ],
    "fallback_to_sample_as_saved_record_allowed": false,
    "fallback_to_dev_store_from_repository_mode_allowed": false
  },
  "store_switch_stopline": {
    "status": "repository_switch_reserved_not_implemented",
