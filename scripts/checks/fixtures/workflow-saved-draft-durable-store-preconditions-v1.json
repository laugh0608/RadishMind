    "required_identity_fields": [
      "tenant_ref",
      "workspace_id",
      "application_id",
      "draft_id",
      "source_definition_id",
      "base_definition_version",
      "draft_version",
      "schema_version"
    ],
    "required_request_scope_fields": [
      "workspace_id",
      "application_id"
    ],
    "scope_denial_failure_code": "draft_scope_denied",
    "scope_denial_returns_draft_body": false,
    "cross_workspace_read_allowed": false,
    "cross_application_read_allowed": false,
    "query_scope_override_allowed": false,
    "sample_fallback_allowed": false
  },
