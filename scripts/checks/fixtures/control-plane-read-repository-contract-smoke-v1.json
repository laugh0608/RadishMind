  "failure_mapping": [
    {
      "source": "missing_or_mismatched_tenant_predicate",
      "failure_code": "tenant_binding_missing"
    },
    {
      "source": "scope_missing_or_denied",
      "failure_code": "scope_denied"
    },
    {
      "source": "unknown_filter_or_sort",
      "failure_code": "invalid_filter"
    },
    {
      "source": "repository_adapter_missing",
      "failure_code": "read_store_unavailable"
    },
    {
      "source": "repository_contract_mismatch",
      "failure_code": "read_store_contract_mismatch"
    },
    {
      "source": "database_backed_mode_disabled",
      "failure_code": "database_read_disabled"
    },
    {
      "source": "auth_context_missing_required_field",
      "failure_code": "auth_context_contract_mismatch"
    }
  ],
  "no_fake_fallback_policy": {
    "status": "required_for_future_smoke",
    "database_mode_requested_failure_code": "database_read_disabled",
    "repository_unavailable_failure_code": "read_store_unavailable",
    "contract_mismatch_failure_code": "read_store_contract_mismatch",
    "fallback_to_fixture_fake_store_allowed": false,
    "fallback_to_test_auth_allowed": false,
    "fallback_to_success_on_unknown_filter_allowed": false
  },
  "no_side_effect_policy": {
    "status": "required_for_future_smoke",
    "side_effect_counters_must_remain": [
      "repository_write_count=0",
      "executor_call_count=0",
      "confirmation_call_count=0",
      "business_writeback_count=0",
      "replay_call_count=0"
