  "store_mode_enablement_matrix": [
    {
      "mode": "memory_dev",
      "current_status": "current_default",
      "enabled_now": true,
      "selector_implementation_required": false,
      "failure_code_when_selected": null,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false
    },
    {
      "mode": "repository_disabled",
      "current_status": "reserved_disabled",
      "enabled_now": false,
      "selector_implementation_required": true,
      "failure_code_when_selected": "repository_store_disabled",
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false
    },
    {
      "mode": "repository",
      "current_status": "future_reserved_disabled",
      "enabled_now": false,
      "selector_implementation_required": true,
      "failure_code_when_selected": "repository_store_disabled",
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false
    },
    {
      "mode": "unknown",
      "current_status": "fail_closed",
      "enabled_now": false,
      "selector_implementation_required": true,
      "failure_code_when_selected": "invalid_draft_store_mode",
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false
    }
  ],
  "operation_selector_matrix": [
    {
      "operation": "SaveWorkflowDraftRecord",
      "default_mode": "memory_dev",
      "reserved_modes": [
        "repository_disabled",
        "repository"
      ],
      "reserved_mode_failure_code": "repository_store_disabled",
      "unknown_mode_failure_code": "invalid_draft_store_mode",
      "selector_enablement_allowed_now": false,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false,
      "side_effect_allowed_on_denied": false
    },
    {
      "operation": "ReadWorkflowDraftRecord",
      "default_mode": "memory_dev",
      "reserved_modes": [
        "repository_disabled",
        "repository"
      ],
      "reserved_mode_failure_code": "repository_store_disabled",
      "unknown_mode_failure_code": "invalid_draft_store_mode",
      "selector_enablement_allowed_now": false,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false,
      "side_effect_allowed_on_denied": false
    },
