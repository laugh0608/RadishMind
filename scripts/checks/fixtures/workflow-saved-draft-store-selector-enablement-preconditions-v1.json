        "repository_disabled",
        "repository"
      ],
      "reserved_mode_failure_code": "repository_store_disabled",
      "unknown_mode_failure_code": "invalid_draft_store_mode",
      "selector_enablement_allowed_now": false,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false,
      "side_effect_allowed_on_denied": false
    }
  ],
  "enablement_gates": [
    {
      "id": "selector_config_boundary_defined",
      "status": "required_now",
      "must_cover": [
        "future config key name",
        "mode allowlist",
        "current default remains memory_dev",
        "unknown mode fails closed"
      ]
    },
    {
      "id": "dev_http_write_boundary_preserved",
      "status": "required_now",
      "must_cover": [
        "RADISHMIND_WORKFLOW_SAVED_DRAFT_DEV_HTTP",
        "RADISHMIND_WORKFLOW_SAVED_DRAFT_DEV_WRITE",
        "dev HTTP enablement separate from store mode"
      ]
    },
    {
      "id": "repository_disabled_gate",
      "status": "required_now",
      "must_cover": [
        "repository_disabled mode returns repository_store_disabled",
        "repository mode returns repository_store_disabled until enabled",
        "reserved modes never fall back to memory_dev"
      ]
    },
    {
      "id": "repository_adapter_gate",
      "status": "not_satisfied",
      "must_cover": [
        "SavedWorkflowDraftRepository interface",
        "repository adapter smoke",
        "store contract mismatch mapping",
        "internal error redaction"
      ]
    },
    {
      "id": "schema_migration_gate",
      "status": "not_satisfied",
      "must_cover": [
        "schema artifact manifest",
        "DDL review evidence",
        "migration smoke",
        "store schema version"
      ]
    },
    {
      "id": "auth_context_gate",
      "status": "not_satisfied",
      "must_cover": [
        "tenant binding",
        "workspace membership",
        "owner policy",
        "scope grants",
        "audit context"
      ]
    },
    {
      "id": "selector_smoke_gate",
      "status": "not_satisfied",
      "must_cover": [
        "unset source selects memory_dev",
        "memory_dev selects platform memory dev store",
        "repository_disabled returns repository_store_disabled",
        "repository returns repository_store_disabled before adapter enablement",
        "unknown mode returns invalid_draft_store_mode"
      ]
    },
    {
      "id": "no_selector_code_leaked",
      "status": "required_now",
      "must_cover": [
        "no formal config entry",
        "no selector function",
        "no selector type",
        "no repository adapter",
        "no SQL or migration files"
      ]
    }
  ],
  "failure_mapping": [
    "repository_store_disabled",
    "invalid_draft_store_mode",
    "draft_store_unavailable",
    "draft_store_contract_mismatch",
    "draft_auth_context_contract_mismatch",
    "draft_schema_migration_not_applied",
    "draft_store_schema_version_mismatch"
  ],
  "dev_flag_boundary": {
    "status": "dev_flags_remain_independent",
    "saved_draft_dev_http_env": "RADISHMIND_WORKFLOW_SAVED_DRAFT_DEV_HTTP",
    "saved_draft_dev_write_env": "RADISHMIND_WORKFLOW_SAVED_DRAFT_DEV_WRITE",
    "store_mode_config_must_not_enable_dev_http": true,
    "store_mode_config_must_not_enable_writes": true
  },
  "no_fallback_policy": {
    "reserved_mode_memory_dev_fallback_allowed": false,
    "reserved_mode_sample_fallback_allowed": false,
    "unknown_mode_success_allowed": false,
    "missing_selector_success_allowed": false,
    "repository_internal_error_exposure_allowed": false
  },
  "no_side_effect_policy": {
    "side_effect_counters_must_remain": [
      "repository_write_count=0",
      "executor_call_count=0",
      "confirmation_call_count=0",
      "business_writeback_count=0",
      "replay_call_count=0"
    ],
    "forbidden_side_effects": [
      "database_write",
      "workflow_execution",
      "confirmation_decision",
      "business_writeback",
      "replay_execution"
    ]
  },
  "implementation_artifact_guard": {
    "status": "forbid_implementation_artifacts",
    "future_files_must_not_exist": [
