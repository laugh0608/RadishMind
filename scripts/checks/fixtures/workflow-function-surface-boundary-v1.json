  "function_surfaces": [
    {
      "id": "application-detail",
      "status": "read_only_surface_defined",
      "source_policy": "offline_fixture_or_future_fake_store_dev_path_only",
      "required_fields": [
        "application_id",
        "tenant_ref",
        "owner_subject_ref",
        "application_type",
        "display_name",
        "lifecycle_status",
        "provider_profile_ref",
        "risk_summary",
        "latest_run_ref",
        "route_ref",
        "audit_ref"
      ],
      "display_expectations": [
        "application identity",
        "provider profile summary",
        "risk summary",
        "latest run pointer",
        "read-only route and audit reference"
      ],
      "capabilities": {
        "can_read": true,
        "can_mutate": false,
        "can_execute": false,
        "can_write_business_truth": false,
        "can_replay": false,
        "can_decide_confirmation": false
      },
      "boundary": "Application detail is a read-only product surface; this slice does not create, edit, delete or publish applications."
    },
    {
      "id": "workflow-definition-detail",
      "status": "read_only_surface_defined",
      "source_policy": "offline_fixture_or_future_fake_store_dev_path_only",
      "required_fields": [
        "workflow_definition_id",
        "tenant_ref",
        "application_ref",
        "version",
        "definition_status",
        "nodes",
        "edges",
        "input_schema_summary",
        "output_schema_summary",
        "risk_level",
        "requires_confirmation_capable",
        "route_ref",
        "audit_ref"
      ],
      "display_expectations": [
        "node list",
        "edge summary",
        "input and output summaries",
        "risk level",
        "requires confirmation capability",
        "read-only route and audit reference"
      ],
      "capabilities": {
        "can_read": true,
        "can_mutate": false,
        "can_execute": false,
        "can_write_business_truth": false,
        "can_replay": false,
        "can_decide_confirmation": false
      },
      "boundary": "Workflow definition detail may explain structure and risk; this slice does not provide a builder, node editor, version publisher or executor."
    },
    {
      "id": "run-detail",
      "status": "read_only_surface_defined",
      "source_policy": "offline_fixture_or_future_fake_store_dev_path_only",
      "required_fields": [
        "run_id",
        "tenant_ref",
        "workflow_definition_ref",
        "application_ref",
        "status",
        "state_timeline",
        "input_summary",
        "output_summary",
        "cost_summary",
        "token_summary",
        "trace_id",
        "failure_code",
        "audit_refs"
      ],
      "display_expectations": [
        "state timeline",
        "input and output summaries",
        "cost and token snapshot",
        "trace id",
        "failure code",
        "audit references"
      ],
      "capabilities": {
        "can_read": true,
        "can_mutate": false,
        "can_execute": false,
        "can_write_business_truth": false,
        "can_replay": false,
        "can_decide_confirmation": false
      },
      "boundary": "Run detail may explain audited run state; this slice does not provide replay, resume, durable run storage or materialized result reads."
    },
    {
      "id": "tool-action-preview",
      "status": "blocked_preview_surface_defined",
      "source_policy": "offline_fixture_or_future_fake_store_dev_path_only",
      "required_fields": [
        "tool_action_id",
        "run_id",
        "node_execution_ref",
        "tool_ref",
        "action_kind",
        "risk_level",
        "requires_confirmation",
        "policy_reason",
        "blocked_state",
        "audit_ref"
      ],
      "display_expectations": [
        "candidate tool action",
        "risk level",
        "requires confirmation flag",
        "policy reason",
        "blocked state",
        "audit reference"
      ],
      "capabilities": {
        "can_read": true,
        "can_mutate": false,
        "can_execute": false,
        "can_write_business_truth": false,
        "can_replay": false,
        "can_decide_confirmation": false
      },
      "boundary": "Tool action preview can explain why an action is blocked; this slice does not execute tools or write upstream business truth."
    },
    {
      "id": "confirmation-placeholder",
      "status": "placeholder_surface_defined",
      "source_policy": "offline_fixture_or_future_fake_store_dev_path_only",
      "required_fields": [
        "confirmation_placeholder_id",
        "required_action_ref",
        "run_id",
        "risk_summary",
        "required_decision_shape",
        "human_review_required",
        "disabled_reason",
        "audit_ref"
      ],
      "display_expectations": [
        "future confirmation decision shape",
        "risk summary",
        "human review requirement",
        "disabled reason",
        "audit reference"
      ],
      "capabilities": {
        "can_read": true,
        "can_mutate": false,
        "can_execute": false,
        "can_write_business_truth": false,
        "can_replay": false,
        "can_decide_confirmation": false
      },
      "boundary": "Confirmation placeholder only previews future decision data; this slice does not submit, persist or unlock confirmation decisions."
    }
  ],
