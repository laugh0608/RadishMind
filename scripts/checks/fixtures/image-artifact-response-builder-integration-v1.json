{
  "schema_version": 1,
  "kind": "image_artifact_response_builder_integration_v1",
  "slice": {
    "id": "image-artifact-response-builder-integration-v1",
    "track": "Image Path",
    "status": "image_artifact_response_builder_integration_task_card_defined",
    "does_not_claim": [
      "response_builder_changed",
      "response_builder_connected",
      "response_builder_runtime_implemented",
      "copilot_response_schema_changed",
      "copilot_response_artifact_runtime_ready",
      "artifact_store_ready",
      "artifact_store_implemented",
      "artifact_binary_reader_ready",
      "artifact_binary_reader_implemented",
      "artifact_binary_read_ready",
      "public_artifact_url_ready",
      "public_url_resolver_ready",
      "signed_url_resolver_ready",
      "production_artifact_storage_ready",
      "image_backend_adapter_implemented",
      "image_backend_client_ready",
      "real_backend_call_ready",
      "image_generation_ready",
      "image_pixel_payload_ready",
      "provider_raw_dump_ready",
      "automatic_retry_ready",
      "fallback_execution_ready",
      "executor_ready",
      "confirmation_decision_ready",
      "writeback_ready",
      "replay_ready",
      "production_ready"
    ]
  },
  "depends_on": [
    "image-artifact-response-builder-integration-entry-review-v1",
    "image-artifact-response-consumer-runtime-implementation-v1",
    "image-artifact-runtime-mapper-runtime-implementation-v1",
    "contracts/copilot-request.schema.json",
    "contracts/copilot-response.schema.json",
    "contracts/image-generation-artifact.schema.json",
    "services/runtime/inference_response.py",
    "services/runtime/image_artifact_response_consumer.py",
    "services/runtime/image_artifact_runtime_mapper.py"
  ],
  "integration_task_card_boundary": {
    "status": "response_builder_integration_task_card_defined_no_runtime_code",
    "decision": "future_coerce_response_document_hook_defined",
    "task_card_created_in_this_slice": true,
    "response_builder_changed_in_this_slice": false,
    "response_builder_connected_in_this_slice": false,
    "response_builder_runtime_code_allowed_in_this_slice": false,
    "copilot_response_schema_changed_in_this_slice": false,
    "artifact_store_created_in_this_slice": false,
    "artifact_binary_reader_created_in_this_slice": false,
    "public_url_resolver_created_in_this_slice": false,
    "backend_adapter_created_in_this_slice": false,
    "metadata_reference_public_output_allowed": false,
    "artifact_store_lookup_allowed_now": false,
    "artifact_binary_read_allowed_now": false,
    "artifact_upload_allowed_now": false,
    "production_storage_write_allowed_now": false,
    "public_url_allowed_now": false,
    "signed_url_allowed_now": false,
    "real_backend_call_allowed_now": false,
    "image_generation_allowed_now": false,
    "dev_server_started_in_this_slice": false
  },
  "exact_hook_placement": {
    "function": "services/runtime/inference_response.py#coerce_response_document",
    "placement": "after_response_top_level_filter_before_existing_schema_validation",
    "after_anchor": "coerced = {key: value for key, value in coerced.items() if key in RESPONSE_TOP_LEVEL_KEYS}",
    "before_anchor": "validate_response_document(coerced)",
    "must_run_after": [
      "normalize_citations_from_document",
      "canonicalize_ghost_response",
      "canonicalize_suggest_edits_response",
      "setdefault required CopilotResponse fields",
      "RESPONSE_TOP_LEVEL_KEYS filtering"
    ],
    "must_run_before": [
      "validate_response_document(coerced)",
      "make_failed_response for schema invalid"
    ],
    "implementation_created_in_this_slice": false
  },
  "request_artifact_metadata_discovery_input": {
    "source": "copilot_request",
    "path": "artifacts[*].metadata.image_generation_artifact",
    "schema": "contracts/image-generation-artifact.schema.json",
    "ordering": "copilot_request.artifacts order",
    "missing_metadata_policy": "no_op_preserve_response",
    "forbidden_sources": [
      "response_document",
      "raw_text",
      "environment_variable",
      "artifact_store_lookup",
      "artifact_binary_reader",
      "public_url_resolver",
      "signed_url_resolver",
      "backend_adapter_response"
    ]
  },
  "post_merge_validation_plan": {
    "mapper_function": "map_image_artifact_to_response_reference",
    "consumer_function": "apply_image_artifact_reference_to_response",
    "schema_validation": "validate_response_document",
    "schema": "contracts/copilot-response.schema.json",
    "post_merge_validation_required": true,
    "metadata_reference_public_output_allowed": false
  },
  "failure_propagation": [
    {
      "case_id": "missing_request_artifact_metadata",
      "expected_action": "no_op_preserve_response",
      "success_response_allowed": true
    },
    {
      "case_id": "mapper_failure",
      "expected_failure_code": "image_artifact_mapper_failed",
      "expected_action": "fail_closed_without_success_citation"
    },
    {
      "case_id": "consumer_citation_id_conflict",
      "expected_failure_code": "image_artifact_citation_id_conflict",
      "expected_action": "fail_closed_without_success_citation"
    },
    {
      "case_id": "consumer_citation_schema_invalid",
      "expected_failure_code": "image_artifact_citation_schema_invalid",
      "expected_action": "fail_closed_without_success_citation"
    },
    {
      "case_id": "consumer_metadata_reference_leak",
      "expected_failure_code": "image_artifact_metadata_reference_leak",
      "expected_action": "fail_closed_without_success_citation"
    },
    {
      "case_id": "post_merge_schema_validation_failure",
      "expected_failure_code": "image_artifact_response_schema_invalid",
      "expected_action": "fail_closed_without_retry_or_backend_call"
    }
  ],
  "source_files_that_must_not_be_connected": [
    "services/runtime/inference_response.py",
    "services/runtime/inference_support.py",
    "services/gateway/copilot_gateway.py",
    "services/platform/internal/httpapi/responses.go"
  ],
  "forbidden_source_literals": [
    "image_artifact_response_consumer",
    "apply_image_artifact_reference_to_response",
    "ImageArtifactResponseConsumerResult",
    "response_consumer_side_effect_counters",
    "map_image_artifact_to_response_reference",
    "ImageArtifactMappingResult",
    "IMAGE_ARTIFACT_PUBLIC_BASE_URL",
    "ReadImageArtifactBinary",
    "ResolveImageArtifactPublicURL",
    "callImageGenerationBackend"
  ],
  "forbidden_artifact_matrix": [
