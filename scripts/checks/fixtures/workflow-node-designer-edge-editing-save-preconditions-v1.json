      "localOnlyInteraction: \"local_edit\""
    ],
    "required_validation_literals": [
      "output_audit_path",
      "orphan_node_scan",
      "edges.some((edge) => edge.edgeKind === \"audit\")"
    ],
    "required_style_literals": [
