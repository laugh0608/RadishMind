      "id": "schema_version_smoke_evidence_gate",
      "status": "not_satisfied",
      "must_cover": [
        "schema version table exists",
        "expected version recorded",
        "missing version maps to schema_migration_not_applied",
        "mismatched version maps to schema_version_mismatch"
      ]
    },
    {
      "id": "tenant_index_smoke_evidence_gate",
      "status": "not_satisfied",
      "must_cover": [
        "tenant_ref leading index per logical entity",
        "cross-tenant read denial",
        "invalid tenant predicate remains fail-closed"
      ]
    },
    {
      "id": "read_only_role_smoke_evidence_gate",
      "status": "not_satisfied",
      "must_cover": [
        "runtime role can read allowed projections",
        "runtime role cannot insert/update/delete",
        "runtime role cannot apply migrations",
        "credential remains secret reference only"
      ]
    },
    {
      "id": "durable_adapter_smoke_dependency_gate",
      "status": "not_satisfied",
      "must_cover": [
        "adapter smoke consumes schema artifact manifest",
        "adapter smoke consumes static runner cases",
        "same failure mapping as fake-store-backed handler path",
        "no write, executor, confirmation, writeback or replay side effects"
      ]
    },
    {
      "id": "no_schema_artifacts_leaked",
      "status": "required_now",
