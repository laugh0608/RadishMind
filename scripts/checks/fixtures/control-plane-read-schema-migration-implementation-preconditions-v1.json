  "implementation_gate_matrix": [
    {
      "id": "schema_readiness_consumed",
      "status": "satisfied",
      "evidence": "control-plane-read-schema-migration-readiness-v1"
    },
    {
      "id": "selector_enablement_preconditions_consumed",
      "status": "satisfied",
      "evidence": "control-plane-read-store-selector-enablement-preconditions-v1"
    },
    {
      "id": "adapter_readiness_refresh_consumed",
      "status": "satisfied",
      "evidence": "control-plane-read-repository-adapter-implementation-readiness-refresh-v1"
    },
    {
      "id": "migration_artifact_manifest_gate",
      "status": "required_now",
      "must_cover": [
        "future manifest path",
        "migration id",
        "up/down artifact references",
        "schema version",
        "tenant index smoke",
        "read-only role smoke"
      ]
    },
    {
      "id": "ddl_review_gate",
      "status": "not_satisfied",
      "must_cover": [
        "human reviewed DDL",
        "no destructive migration without review",
        "manual apply command",
        "no service startup auto-migration"
      ]
    },
    {
      "id": "rollback_fixture_gate",
      "status": "not_satisfied",
      "must_cover": [
        "rollback path or forward-only exception",
        "backup requirement",
        "failed migration recovery",
        "migration lock release"
      ]
    },
    {
      "id": "schema_version_smoke_gate",
      "status": "not_satisfied",
      "must_cover": [
        "schema version table exists",
        "expected version recorded",
        "missing version maps to schema_migration_not_applied",
        "mismatched version maps to schema_version_mismatch"
      ]
    },
    {
      "id": "tenant_index_smoke_gate",
      "status": "not_satisfied",
      "must_cover": [
        "tenant_ref leading index on every logical entity",
        "cross-tenant read denial",
        "invalid tenant predicate remains fail-closed"
      ]
    },
    {
      "id": "read_only_role_smoke_gate",
      "status": "not_satisfied",
      "must_cover": [
        "runtime role can read allowed projections",
        "runtime role cannot insert/update/delete",
        "runtime role cannot apply migrations",
        "credential is secret reference only"
      ]
    },
    {
      "id": "no_migration_artifacts_leaked",
      "status": "required_now",
      "must_cover": [
        "no migration directory",
        "no SQL files",
        "no migration runner",
        "no database/sql import",
        "no repository adapter",
        "no store selector"
      ]
    }
  ],
