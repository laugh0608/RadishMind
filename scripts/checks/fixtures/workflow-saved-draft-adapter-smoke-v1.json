      "request_type": "SaveWorkflowDraftRecordRequest",
      "result_type": "SaveWorkflowDraftRecordResult",
      "adapter_method": "SaveWorkflowDraftRecord",
      "expected_success_projection": "sanitized_saved_draft_record_with_current_version_metadata",
      "static_contract_case_consumed": true,
      "adapter_method_called": true,
      "fake_query_executor_call_count": 1,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false,
      "fallback_to_fixture_allowed": false,
      "fallback_to_dev_http_route_allowed": false
    },
    {
      "operation": "ReadWorkflowDraftRecord",
      "required_scope": "workflow_drafts:read",
      "request_type": "ReadWorkflowDraftRecordRequest",
      "result_type": "ReadWorkflowDraftRecordResult",
      "adapter_method": "ReadWorkflowDraftRecord",
      "expected_success_projection": "sanitized_saved_draft_record",
      "static_contract_case_consumed": true,
      "adapter_method_called": true,
      "fake_query_executor_call_count": 1,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false,
      "fallback_to_fixture_allowed": false,
      "fallback_to_dev_http_route_allowed": false
    },
    {
      "operation": "ListWorkflowDraftRecords",
      "required_scope": "workflow_drafts:read",
      "request_type": "ListWorkflowDraftRecordsRequest",
      "result_type": "ListWorkflowDraftRecordsResult",
      "adapter_method": "ListWorkflowDraftRecords",
      "expected_success_projection": "sanitized_saved_draft_summary_list",
      "static_contract_case_consumed": true,
      "adapter_method_called": true,
      "fake_query_executor_call_count": 1,
      "fallback_to_memory_dev_store_allowed": false,
      "fallback_to_sample_allowed": false,
      "fallback_to_fixture_allowed": false,
      "fallback_to_dev_http_route_allowed": false
    }
  ],
  "failure_mapping": {
    "status": "adapter_smoke_fail_closed_executed",
    "required_failure_codes": [
      "draft_scope_denied",
      "draft_not_found",
      "draft_schema_version_unsupported",
      "draft_payload_invalid",
      "draft_version_conflict",
      "draft_store_unavailable",
      "draft_store_contract_mismatch",
      "repository_store_disabled",
      "invalid_draft_store_mode",
      "draft_auth_context_contract_mismatch",
      "draft_schema_migration_not_applied",
      "draft_store_schema_version_mismatch",
      "draft_store_migration_unavailable",
      "draft_identity_context_missing",
      "draft_tenant_binding_missing",
      "draft_workspace_membership_denied",
      "draft_scope_grant_missing"
    ],
    "executed_failure_codes": [
      "draft_not_found",
      "draft_version_conflict",
      "draft_store_unavailable",
      "draft_store_contract_mismatch",
      "draft_auth_context_contract_mismatch",
      "draft_schema_migration_not_applied",
      "draft_store_schema_version_mismatch",
      "draft_store_migration_unavailable",
      "draft_scope_grant_missing"
    ],
    "version_conflict_must_not_be_rewritten": true,
    "not_found_must_not_fallback_to_sample": true,
    "scope_denied_must_not_return_draft_payload": true,
    "contract_mismatch_must_not_leak_database_detail": true,
    "schema_failure_must_prevent_query_execution": true
  },
  "no_fallback_policy": {
    "fallback_to_memory_dev_store_allowed": false,
    "fallback_to_sample_allowed": false,
    "fallback_to_fixture_allowed": false,
    "fallback_to_dev_http_route_allowed": false,
    "fallback_to_test_auth_allowed": false,
    "success_on_missing_schema_artifact_allowed": false,
    "success_on_auth_context_mismatch_allowed": false,
    "success_on_contract_mismatch_allowed": false,
    "reserved_store_mode_success_allowed": false,
    "unknown_store_mode_success_allowed": false
  },
  "no_side_effect_policy": {
    "allowed_test_state": "injected_fake_query_executor_state",
    "side_effect_counters_must_remain": [
      "database_connection_count=0",
      "external_repository_write_count=0",
      "executor_call_count=0",
      "confirmation_call_count=0",
      "business_writeback_count=0",
      "replay_call_count=0"
    ],
    "forbidden_side_effects": [
      "database_connection",
      "sql_execution",
      "oidc_network_call",
      "workflow_execution",
      "confirmation_decision",
      "business_writeback",
      "replay_execution",
      "production_api_call"
    ]
  },
