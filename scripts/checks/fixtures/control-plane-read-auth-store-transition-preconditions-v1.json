  "auth_middleware_transition_gates": [
    {
      "id": "issuer-discovery-contract",
      "status": "required_before_auth_middleware",
      "rule": "Radish issuer discovery and client metadata must be contract-backed before route middleware consumes tokens"
    },
    {
      "id": "token-validation-contract",
      "status": "required_before_auth_middleware",
      "rule": "Token validation rules must be defined as a separate contract before implementation"
    },
    {
      "id": "claim-mapping-contract",
      "status": "required_before_auth_middleware",
      "rule": "issuer, subject, tenant_ref, scopes, roles and permissions must map into the read auth context"
    },
    {
      "id": "tenant-binding-enforcement",
      "status": "required_before_auth_middleware",
      "rule": "tenant_ref must come from trusted auth context and must reject query-string tenant overrides"
    },
    {
      "id": "scope-grant-projection",
      "status": "required_before_auth_middleware",
      "rule": "route scopes must be projected from auth context and fail closed when absent"
    },
    {
      "id": "audit-context-propagation",
      "status": "required_before_auth_middleware",
      "rule": "request_id, actor, issuer and session refs must propagate to read response audit refs"
    },
    {
      "id": "fail-closed-missing-identity",
      "status": "required_before_auth_middleware",
      "rule": "missing identity, tenant binding, subject or scope grants must return fail-closed envelopes"
    },
    {
      "id": "no-public-fake-auth-in-production",
      "status": "required_before_auth_middleware",
      "rule": "dev fake auth headers must not become public production auth inputs"
    },
    {
      "id": "dev-fake-auth-disabled-by-default",
      "status": "required_before_auth_middleware",
      "rule": "RADISHMIND_CONTROL_PLANE_READ_DEV_AUTH must remain disabled unless explicitly enabled for local development"
    }
  ],
  "read_store_transition_gates": [
    {
      "id": "repository-interface-before-sql",
      "status": "required_before_read_store",
      "rule": "A narrow read repository interface must exist before SQL, migration or durable adapter work starts"
    },
    {
      "id": "tenant-predicate-from-auth-context",
      "status": "required_before_read_store",
      "rule": "Every repository read must receive tenant_ref from auth context and preserve tenant-scoped access"
    },
    {
      "id": "sanitized-summary-projection",
      "status": "required_before_read_store",
      "rule": "Repository outputs must be summary projections and must not include raw secret, token, prompt or tool payload fields"
    },
    {
      "id": "cursor-filter-sort-allowlist",
      "status": "required_before_read_store",
      "rule": "List reads must validate cursor, limit, filter and sort values against route allowlists"
    },
    {
      "id": "read-store-failure-taxonomy",
      "status": "required_before_read_store",
      "rule": "Repository failures must map to the read-side failure taxonomy without leaking database internals"
    },
    {
      "id": "no-database-write",
      "status": "required_before_read_store",
      "rule": "Read repository methods must not mutate state, write audit records inline or call workflow executors"
    },
    {
      "id": "no-secret-material",
      "status": "required_before_read_store",
      "rule": "Read repository fixtures and tests must not store secret values, bearer tokens, cookies or API key values"
    }
  ],
