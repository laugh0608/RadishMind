{
  "schema_version": 1,
  "kind": "session_tooling_independent_audit_records_design",
  "stage": "P2 Session & Tooling Foundation",
  "status": "design_only_not_connected",
  "source_preconditions": "scripts/checks/fixtures/session-tooling-implementation-preconditions.json",
  "source_confirmation_flow_design": "scripts/checks/fixtures/session-tooling-confirmation-flow-design.json",
  "source_tool_audit_record_fixture": "scripts/checks/fixtures/tool-audit-record-basic.json",
  "task_card": "docs/task-cards/session-tooling-independent-audit-records.md",
  "scope": {
    "area": "independent_audit_records",
    "current_boundary": "record_shape_and_event_sources_only",
    "audit_store_enabled": false,
    "execution_enabled": false,
    "result_materialization_enabled": false,
    "writes_business_truth": false,
    "replay_enabled": false
  },
  "audit_record_shape": {
    "required_fields": [
      "audit_record_id",
      "event_type",
      "event_source",
      "occurred_at",
      "request_id",
      "session_id",
      "turn_id",
      "subject_ref",
      "actor_ref",
      "correlation_refs",
      "payload_hash",
      "boundary_decision",
      "side_effects",
      "redaction",
      "storage_policy"
    ],
    "correlation_refs": [
      "confirmation_id",
      "action_ref",
      "tool_audit_ref",
      "checkpoint_id",
      "policy_decision_ref"
    ],
    "side_effects": {
      "allowed_current_values": [
        "none",
        "metadata_recorded"
      ],
      "forbidden_current_values": [
        "execution_status=executed",
        "writes_business_truth=true",
        "materialized_result_ref",
        "durable_memory_written=true",
        "replay_started=true"
      ]
    },
    "redaction": {
      "requires_secret_redaction": true,
      "requires_payload_hash": true,
      "stores_raw_tool_output": false,
      "stores_credentials": false
    },
    "storage_policy": {
      "current_mode": "fixture_only",
      "durable_store_status": "not_implemented",
      "retention_policy_status": "not_defined",
      "checkpoint_read_may_reference_audit_ref": true,
      "checkpoint_read_is_audit_store": false
    }
  },
  "event_sources": [
    {
      "source": "confirmation_flow",
      "events": [
        "confirmation_requested",
        "confirmation_recorded",
        "confirmation_rejected",
        "confirmation_deferred",
        "confirmation_invalidated"
      ],
      "boundary": "records confirmation request and outcome metadata only; approve never executes the action"
    },
    {
      "source": "executor_policy_gate",
      "events": [
        "executor_attempt_blocked",
        "executor_execution_not_enabled"
      ],
      "boundary": "future executor attempts must emit audit records, but current design only records blocked/not_executed decisions"
    },
    {
      "source": "storage_policy_gate",
      "events": [
        "storage_materialization_denied",
        "durable_memory_write_denied",
        "business_truth_write_denied"
      ],
      "boundary": "audit metadata can explain storage denials, but it is not a durable store or materialized result reader"
    },
    {
      "source": "checkpoint_read_route",
      "events": [
        "checkpoint_metadata_read_served",
        "checkpoint_read_query_denied"
      ],
      "boundary": "checkpoint read may expose audit refs and summaries, not raw audit payloads or execution outputs"
    },
    {
      "source": "tool_registry_policy",
      "events": [
        "tool_policy_decision_recorded",
        "tool_network_denied"
      ],
      "boundary": "registry and tool policy decisions remain advisory and disabled for real execution"
    },
    {
      "source": "northbound_request",
      "events": [
        "northbound_request_received",
        "northbound_failure_boundary_recorded"
      ],
      "boundary": "northbound route metadata can be correlated with audit records but does not write business truth"
    }
  ],
  "boundary_alignment": {
    "confirmation": [
      "confirmation records may carry audit_ref, but audit_ref is evidence metadata, not an approval engine",
      "approve/reject/defer outcomes remain design-only until upper_layer_confirmation_flow is implemented",
      "approved confirmation must still remain approved_pending_execution_boundary, not executed"
    ],
    "executor": [
      "current executor state is not_implemented and execution_enabled=false",
      "future execution attempts must create audit records before and after policy decisions",
      "audit records must not carry executor_ref, tool output, or execution_status=executed in current scope"
    ],
    "storage": [
      "current audit records are fixture-only and do not create a durable audit store",
      "storage, checkpoint, materialized result, and audit responsibilities must stay separated",
      "checkpoint read may reference audit summaries but must not become audit storage or result materialization"
    ]
  },
  "not_enabled_capabilities": [
    "automatic_replay",
    "business_truth_write",
    "confirmed_action_execution",
    "durable_audit_store",
    "durable_memory",
    "durable_session_store",
    "durable_tool_store",
    "long_term_memory",
    "materialized_result_reader",
    "real_tool_executor",
    "result_materialization"
  ],
  "precondition_status_after_design": {
    "independent_audit_records": "design_boundary_defined_not_implemented",
    "upper_layer_confirmation_flow": "not_satisfied",
    "executor_boundary": "not_satisfied",
    "storage_backend_design": "not_satisfied",
    "result_materialization_policy": "not_satisfied",
    "negative_regression_suite": "not_satisfied"
  },
  "consumers": [
    {
      "path": "scripts/check-session-tooling-independent-audit-records.py",
      "coverage": "validates_independent_audit_record_design_shape_event_sources_and_boundaries"
    },
    {
      "path": "scripts/check-repo.py",
      "coverage": "fast_baseline_entrypoint"
    }
  ]
}
