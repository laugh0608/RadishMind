    "forbidden_fields": [
      "pixel_payload",
      "base64_image",
      "provider_raw_response",
      "external_moderation_result",
      "signed_public_url",
      "storage_write_result",
      "human_confirmation_decision",
      "executor_ref",
      "writeback_ref",
      "replay_ref"
    ]
  },
  "safety_runbook_steps": [
    {
      "order": 1,
      "step_id": "core_intent_safety_precheck",
      "input": "image_generation intent",
      "checks": [
        "prompt present",
        "negative prompt present",
        "constraints present",
        "risk level present",
        "requires confirmation flag present"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 2,
      "step_id": "adapter_safety_gate_before_backend_request",
      "input": "image_generation intent",
      "output": "image_generation_backend_request",
      "required_evidence": [
        "image-adapter-handshake-safety-gate-v1"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 3,
      "step_id": "block_confirmation_required_or_high_risk",
      "input": "intent safety",
      "output": "blocked_requires_confirmation",
      "blocked_conditions": [
        "requires_confirmation=true",
        "risk_level=high",
        "policy_unknown"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 4,
      "step_id": "backend_request_safety_trace_review",
      "input": "image_generation_backend_request",
      "checks": [
        "safety gate present",
        "risk level propagated",
        "confirmation flag propagated",
        "trace ids present"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 5,
      "step_id": "artifact_metadata_safety_review",
      "input": "image_generation_artifact",
      "checks": [
        "review status present",
        "risk level present",
        "confirmation flag present",
        "hash present",
        "provenance present"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 6,
      "step_id": "route_failed_or_blocked_safety_metadata",
      "input": "artifact safety review",
      "output": "blocked or failed metadata status",
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 7,
      "step_id": "defer_runtime_policy_engine_and_moderation_provider",
      "input": "safety runbook",
      "output": "blocked runtime implementation",
      "allowed_now": false,
      "runtime_implemented_now": false
    }
  ],
  "safety_decision_matrix": [
    {
      "case_id": "low_risk_no_confirmation",
      "intent_risk_level": "low",
      "requires_confirmation": false,
      "expected_backend_gate": "approved_for_backend",
      "artifact_review_status": "not_required",
      "metadata_reference_allowed_by_runbook": true,
      "backend_call_allowed_now": false,
      "runtime_return_implemented_now": false
    },
    {
      "case_id": "confirmation_required",
      "intent_risk_level": "medium",
      "requires_confirmation": true,
      "expected_backend_gate": "blocked_requires_confirmation",
      "artifact_review_status": "pending_review",
      "metadata_reference_allowed_by_runbook": false,
      "backend_call_allowed_now": false,
      "runtime_return_implemented_now": false
    },
    {
      "case_id": "high_risk_or_policy_unknown",
      "intent_risk_level": "high",
      "requires_confirmation": true,
      "expected_backend_gate": "blocked_requires_confirmation",
      "artifact_review_status": "blocked",
      "metadata_reference_allowed_by_runbook": false,
      "backend_call_allowed_now": false,
      "runtime_return_implemented_now": false
    },
    {
      "case_id": "backend_unavailable_after_gate",
      "intent_risk_level": "low",
      "requires_confirmation": false,
      "failure_code": "image_backend_unavailable",
      "metadata_reference_allowed_by_runbook": false,
      "backend_call_allowed_now": false,
      "runtime_return_implemented_now": false
    },
    {
      "case_id": "artifact_review_pending",
      "intent_risk_level": "medium",
      "requires_confirmation": true,
      "failure_code": "image_artifact_safety_pending_review",
      "artifact_review_status": "pending_review",
      "metadata_reference_allowed_by_runbook": false,
      "backend_call_allowed_now": false,
      "runtime_return_implemented_now": false
    },
    {
      "case_id": "artifact_review_blocked",
      "intent_risk_level": "high",
      "requires_confirmation": true,
      "failure_code": "image_artifact_safety_blocked",
      "artifact_review_status": "blocked",
      "metadata_reference_allowed_by_runbook": false,
      "backend_call_allowed_now": false,
      "runtime_return_implemented_now": false
    }
  ],
  "failure_taxonomy": [
    {
      "failure_code": "image_prompt_policy_unknown",
      "source": "intent safety precheck",
      "response_policy": "block before backend request mapping",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": false,
      "artifact_reference_returned": false
    },
    {
      "failure_code": "image_intent_requires_confirmation",
      "source": "intent safety precheck",
      "response_policy": "block before backend submission",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": false,
      "artifact_reference_returned": false
    },
    {
      "failure_code": "image_intent_high_risk",
      "source": "intent safety precheck",
      "response_policy": "block until human review and policy gate exist",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": false,
      "artifact_reference_returned": false
    },
    {
      "failure_code": "image_backend_safety_gate_blocked",
      "source": "adapter safety gate",
      "response_policy": "return blocked metadata status without backend call",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": true,
      "artifact_reference_returned": false
    },
    {
      "failure_code": "image_backend_unavailable",
      "source": "adapter safety gate or backend dispatch",
      "response_policy": "return blocked metadata status without retry loop",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": true,
      "artifact_reference_returned": false
    },
    {
      "failure_code": "image_artifact_safety_pending_review",
      "source": "artifact safety review",
      "response_policy": "return pending review metadata status only",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": true,
      "artifact_reference_returned": false
    },
    {
      "failure_code": "image_artifact_safety_blocked",
      "source": "artifact safety review",
      "response_policy": "return safety blocked metadata status only",
      "retry_or_fallback_allowed_now": false,
      "backend_request_created": true,
      "artifact_reference_returned": false
    }
  ],
  "artifact_safety_review_requirements": {
    "required_fields": [
      "safety.risk_level",
      "safety.requires_confirmation",
      "safety.review_status",
      "safety.review_notes",
      "artifact.sha256",
      "artifact.uri",
      "provenance.trace_ids"
    ],
    "allowed_review_statuses": [
      "not_required",
      "pending_review",
      "reviewed_pass",
      "blocked"
    ],
    "blocked_review_statuses": [
      "pending_review",
      "blocked"
    ],
    "artifact_reference_return_blocked_when": [
      "review_status=pending_review",
      "review_status=blocked",
      "risk_level=high",
      "requires_confirmation=true"
    ]
  },
  "artifact_visibility_policy": {
    "metadata_visible_to_safety_runbook": true,
    "pixel_payload_visible_to_safety_runbook": false,
    "provider_raw_dump_visible_to_safety_runbook": false,
