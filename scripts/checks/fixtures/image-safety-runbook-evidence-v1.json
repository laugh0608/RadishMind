    "public_url_allowed_now": false,
    "production_storage_allowed_now": false,
    "dev_server_started_in_this_slice": false
  },
  "policy_input_fields": {
    "status": "defined_not_executable",
    "runtime_policy_engine_required_now": false,
    "required_fields": [
      {
        "source": "intent",
        "path": "prompt.positive"
      },
      {
        "source": "intent",
        "path": "prompt.negative"
      },
      {
        "source": "intent",
        "path": "constraints.must_include"
      },
      {
        "source": "intent",
        "path": "constraints.must_avoid"
      },
      {
        "source": "intent",
        "path": "safety.requires_confirmation"
      },
      {
        "source": "intent",
        "path": "safety.risk_level"
      },
      {
        "source": "intent",
        "path": "safety.review_notes"
      },
      {
        "source": "backend_request",
        "path": "safety.gate"
      },
      {
        "source": "backend_request",
        "path": "safety.requires_confirmation"
      },
      {
        "source": "backend_request",
        "path": "safety.risk_level"
      },
      {
        "source": "backend_request",
        "path": "trace.trace_ids"
      },
      {
        "source": "artifact",
        "path": "safety.risk_level"
      },
      {
        "source": "artifact",
        "path": "safety.requires_confirmation"
      },
      {
        "source": "artifact",
        "path": "safety.review_status"
      },
      {
        "source": "artifact",
        "path": "safety.review_notes"
      },
