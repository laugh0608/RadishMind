    "source_intent_schema": "contracts/image-generation-intent.schema.json",
    "source_backend_request_schema": "contracts/image-generation-backend-request.schema.json",
    "source_artifact_schema": "contracts/image-generation-artifact.schema.json",
    "upstream_handshake_fixture": "scripts/checks/fixtures/image-adapter-handshake-safety-gate-v1.json",
    "upstream_artifact_return_fixture": "scripts/checks/fixtures/image-artifact-return-runbook-evidence-v1.json",
    "copilot_response_schema_changed_in_this_slice": false,
    "image_safety_runtime_created_in_this_slice": false,
    "image_safety_classifier_created_in_this_slice": false,
    "runtime_policy_engine_created_in_this_slice": false,
    "moderation_provider_created_in_this_slice": false,
    "image_backend_client_created_in_this_slice": false,
    "artifact_store_created_in_this_slice": false,
    "real_backend_call_allowed_now": false,
