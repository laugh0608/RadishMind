      "checks": [
        "artifact:// uri",
        "sha256 present",
        "dimensions present",
        "backend provenance present",
        "safety review present"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 3,
      "step_id": "redact_non_metadata_payload",
      "input": "image_generation_artifact",
      "forbidden_payloads": [
        "pixel_payload",
        "base64_image",
        "provider_raw_response",
        "public_url"
      ],
      "allowed_now": true,
      "runtime_implemented_now": false
    },
    {
      "order": 4,
      "step_id": "map_to_future_response_reference",
      "input": "metadata_reference_shape",
      "output": "future CopilotResponse artifact metadata reference",
      "allowed_now": false,
      "runtime_implemented_now": false
    },
    {
      "order": 5,
      "step_id": "defer_binary_retrieval_to_future_artifact_store",
      "input": "artifact:// uri",
      "output": "blocked_binary_reader",
      "allowed_now": false,
      "runtime_implemented_now": false
    }
