  "database_read_store_preconditions": {
    "status": "preconditions_defined_not_implemented",
    "future_source": "future control plane read store repository",
    "repository_contract": [
      {
        "id": "repository-interface-before-sql",
        "status": "required_before_implementation",
        "rule": "Define a narrow read repository interface before adding SQL, migrations or durable store adapters"
      },
      {
        "id": "tenant-predicate-required",
        "status": "required_before_implementation",
        "rule": "Every repository read must carry tenant_ref from auth context and must not trust query-string tenant overrides"
      },
      {
        "id": "sanitized-projection-required",
        "status": "required_before_implementation",
        "rule": "Repository results must return summary projections only and must not expose raw secrets, tokens, prompts or tool payloads"
      }
    ],
