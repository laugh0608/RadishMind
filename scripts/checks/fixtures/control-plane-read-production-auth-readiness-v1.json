  "issuer_discovery_evidence_contract": {
    "status": "required_before_production_auth",
    "network_call_allowed_now": false,
    "committed_raw_discovery_document_allowed": false,
    "committed_raw_jwks_allowed": false,
    "required_fields": [
      "issuer_url",
      "discovery_document_url",
      "jwks_uri",
      "supported_signing_algorithms",
      "supported_scopes",
      "fetched_at",
      "expires_at",
