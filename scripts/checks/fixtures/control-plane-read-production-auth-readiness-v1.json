      "operator_review_ref",
      "sanitized_evidence_ref"
    ]
  },
  "token_validation_contract_preconditions": [
    {
      "id": "issuer-metadata-pinned",
      "status": "required_before_token_validation",
      "rule": "Token validation must consume reviewed issuer discovery evidence, not ad hoc runtime defaults."
    },
    {
      "id": "jwks-refresh-policy",
      "status": "required_before_token_validation",
      "rule": "JWKS refresh, cache expiry and key rotation failure mapping must be defined before middleware validates tokens."
    },
    {
      "id": "algorithm-allowlist",
      "status": "required_before_token_validation",
      "rule": "Accepted signing algorithms must come from issuer evidence and fail closed for unsupported alg values."
    },
    {
      "id": "issuer-audience-checks",
      "status": "required_before_token_validation",
      "rule": "Issuer, audience and client id checks must be explicit and tenant independent."
    },
    {
      "id": "time-window-checks",
      "status": "required_before_token_validation",
      "rule": "exp, nbf, iat and clock skew rules must map expired or not-yet-valid tokens to sanitized failures."
    },
    {
      "id": "required-claim-checks",
      "status": "required_before_token_validation",
      "rule": "sub, tenant_id and permission-bearing claims must be present before creating read auth context."
    },
    {
      "id": "sanitized-failure-envelope",
      "status": "required_before_token_validation",
      "rule": "Token validation failures must map to read-side failure codes without exposing token, header or JWKS material."
    }
  ],
