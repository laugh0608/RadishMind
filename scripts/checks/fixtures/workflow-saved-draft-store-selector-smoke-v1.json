      "failure_code": "repository_store_disabled",
      "fallback_to_memory_dev_allowed": false
    },
    {
      "mode": "repository",
      "expected_result": "disabled_store",
      "success_allowed": false,
      "failure_code": "repository_store_disabled",
      "fallback_to_memory_dev_allowed": false
    },
    {
      "mode": "unknown",
      "expected_result": "disabled_store",
      "success_allowed": false,
      "failure_code": "invalid_draft_store_mode",
      "fallback_to_memory_dev_allowed": false
    }
  ],
