{
  "schema_version": 1,
  "kind": "workflow_saved_draft_repository_mode_enablement_v1",
  "slice": {
    "id": "workflow-saved-draft-repository-mode-enablement-v1",
    "track": "Workflow / Agent Runtime",
    "status": "draft_repository_mode_enablement_review_defined",
    "does_not_claim": [
      "repository_store_mode_enabled",
      "durable_persistence_ready",
      "database_connection_ready",
      "database_query_ready",
      "sql_migration_created",
      "migration_runner_implemented",
      "schema_version_table_created",
      "oidc_middleware_ready",
      "token_validation_ready",
      "workspace_membership_adapter_ready",
      "production_api_consumer_ready",
      "workflow_publish_ready",
      "workflow_executor_ready",
      "confirmation_decision_ready",
      "business_writeback_ready",
      "run_replay_ready",
      "production_ready"
    ]
  },
  "depends_on": [
    "workflow-saved-draft-store-selector-smoke-v1",
    "workflow-saved-draft-schema-artifact-materialization-v1",
    "workflow-saved-draft-repository-adapter-implementation-v1",
    "workflow-saved-draft-adapter-smoke-v1",
    "workflow-saved-draft-production-auth-runtime-v1"
  ],
  "runtime_boundary": {
    "status": "repository_mode_enablement_review_defined_no_runtime_enablement",
    "decision": "repository_mode_not_enabled",
    "selector_file": "services/platform/internal/httpapi/workflow_saved_draft_store_selector.go",
    "route_store_file": "services/platform/internal/httpapi/workflow_saved_draft_http.go",
    "repository_adapter_file": "services/platform/internal/httpapi/workflow_saved_draft_repository_adapter.go",
    "production_auth_runtime_file": "services/platform/internal/httpapi/workflow_saved_draft_production_auth_runtime.go",
    "repository_store_mode_success_allowed_now": false,
    "selector_adapter_binding_allowed_now": false,
    "database_connection_allowed_now": false,
    "sql_execution_allowed_now": false,
    "migration_runner_allowed_now": false,
    "oidc_middleware_allowed_now": false,
    "token_validation_allowed_now": false,
    "membership_adapter_allowed_now": false,
    "production_api_allowed_now": false,
    "executor_allowed_now": false
  },
  "config_gate_matrix": [
    {
      "gate_id": "memory_dev_default",
      "config_key": "RADISHMIND_WORKFLOW_SAVED_DRAFT_STORE",
      "status": "satisfied",
      "expected_behavior": "memory_dev_store_selected"
    },
    {
      "gate_id": "repository_reserved_fail_closed",
      "config_key": "RADISHMIND_WORKFLOW_SAVED_DRAFT_STORE=repository",
      "status": "satisfied",
      "expected_behavior": "repository_store_disabled"
    },
    {
      "gate_id": "repository_disabled_reserved_fail_closed",
      "config_key": "RADISHMIND_WORKFLOW_SAVED_DRAFT_STORE=repository_disabled",
      "status": "satisfied",
      "expected_behavior": "repository_store_disabled"
    },
    {
      "gate_id": "unknown_mode_fail_closed",
      "config_key": "RADISHMIND_WORKFLOW_SAVED_DRAFT_STORE=<unknown>",
      "status": "satisfied",
      "expected_behavior": "invalid_draft_store_mode"
    },
    {
      "gate_id": "repository_runtime_enablement_config",
      "config_key": "future_production_repository_enablement",
      "status": "not_satisfied",
      "expected_behavior": "no_runtime_enablement"
    },
    {
      "gate_id": "selector_adapter_binding",
      "config_key": "future_selector_repository_adapter_binding",
      "status": "not_satisfied",
      "expected_behavior": "selector_must_not_construct_repository_adapter"
    }
  ],
  "schema_preflight_matrix": [
    {
      "gate_id": "static_schema_artifact_materialized",
      "source": "workflow-saved-draft-schema-artifact-materialization-v1",
      "status": "satisfied"
    },
    {
      "gate_id": "adapter_schema_preflight_implemented",
      "source": "workflow-saved-draft-repository-adapter-implementation-v1",
      "status": "satisfied"
    },
    {
      "gate_id": "executable_sql_migration_available",
      "status": "not_satisfied"
    },
    {
      "gate_id": "schema_version_table_available",
      "status": "not_satisfied"
    },
    {
      "gate_id": "runtime_migration_runner_available",
      "status": "not_satisfied"
    }
  ],
  "dependency_gate_matrix": [
    {
      "gate_id": "repository_adapter_implemented",
      "source": "workflow-saved-draft-repository-adapter-implementation-v1",
      "status": "satisfied"
    },
    {
      "gate_id": "adapter_smoke_executed_with_fake_query_executor",
      "source": "workflow-saved-draft-adapter-smoke-v1",
      "status": "satisfied"
    },
    {
      "gate_id": "production_auth_runtime_bridge_implemented",
      "source": "workflow-saved-draft-production-auth-runtime-v1",
      "status": "satisfied"
    },
    {
      "gate_id": "real_repository_query_executor_smoke",
      "status": "not_satisfied"
    },
    {
      "gate_id": "oidc_middleware_token_validation_membership_adapter",
      "status": "not_satisfied"
    },
    {
      "gate_id": "production_api_consumer_smoke",
      "status": "not_satisfied"
    }
  ],
  "failure_mapping": {
    "status": "repository_mode_enablement_fail_closed_review_defined",
    "required_failure_codes": [
      "repository_store_disabled",
      "invalid_draft_store_mode",
      "draft_schema_migration_not_applied",
      "draft_store_schema_version_mismatch",
      "draft_store_migration_unavailable",
      "draft_auth_context_contract_mismatch",
      "draft_identity_context_missing",
      "draft_tenant_binding_missing",
      "draft_workspace_membership_denied",
      "draft_application_scope_denied",
      "draft_owner_scope_denied",
      "draft_scope_grant_missing",
      "draft_store_unavailable",
      "draft_store_contract_mismatch"
    ],
    "reserved_repository_mode_failure_code": "repository_store_disabled",
    "unknown_mode_failure_code": "invalid_draft_store_mode",
    "schema_preflight_failure_must_prevent_query_execution": true,
    "auth_failure_must_not_return_draft_payload": true,
    "store_failure_must_not_fallback_to_memory_dev": true,
    "contract_mismatch_must_not_leak_database_detail": true
  },
  "rollback_policy": {
    "static_rollback_evidence": "services/platform/migrations/workflow_saved_drafts/rollback-evidence.json",
    "static_rollback_evidence_status": "satisfied",
    "runtime_rollback_runner_status": "not_satisfied",
    "repository_mode_rollback_smoke_status": "not_satisfied",
    "rollback_to_memory_dev_after_repository_failure_allowed": false
  },
  "no_fallback_policy": {
    "repository_mode_fallback_to_memory_dev_allowed": false,
    "repository_mode_fallback_to_sample_allowed": false,
    "repository_mode_fallback_to_fixture_allowed": false,
    "repository_mode_fallback_to_dev_http_route_allowed": false,
    "repository_mode_fallback_to_test_auth_allowed": false,
    "schema_failure_fallback_to_success_allowed": false,
    "auth_failure_fallback_to_admin_allowed": false,
    "adapter_smoke_fake_executor_promoted_to_runtime_allowed": false
  },
  "no_side_effect_policy": {
    "side_effect_counters_must_remain": [
      "database_connection_count=0",
      "sql_execution_count=0",
      "repository_write_count=0",
      "executor_call_count=0",
      "confirmation_call_count=0",
      "business_writeback_count=0",
      "replay_call_count=0"
    ],
    "forbidden_side_effects": [
      "database_connection",
      "sql_execution",
      "repository_write",
      "oidc_network_call",
      "token_validation_runtime_call",
      "membership_adapter_call",
      "production_api_call",
      "workflow_execution",
      "confirmation_decision",
      "business_writeback",
      "replay_execution"
    ]
  },
  "artifact_guard": {
    "files_must_not_exist": [
      "services/platform/internal/httpapi/workflow_saved_draft_repository_mode.go",
      "services/platform/internal/httpapi/workflow_saved_draft_repository_query_executor_sql.go",
      "services/platform/internal/httpapi/workflow_saved_draft_schema_migration_runner.go",
      "services/platform/internal/httpapi/workflow_saved_draft_auth_middleware.go",
      "services/platform/internal/httpapi/workflow_saved_draft_token_validation.go",
      "services/platform/internal/httpapi/workflow_saved_draft_membership_adapter.go",
      "services/platform/internal/httpapi/workflow_saved_draft_production_api.go"
    ],
    "source_files_to_scan": [
      "services/platform/internal/httpapi/workflow_saved_draft_store_selector.go",
      "services/platform/internal/httpapi/workflow_saved_draft_http.go"
    ],
    "forbidden_source_literals": [
      "NewSavedWorkflowDraftRepositoryAdapter",
      "SavedWorkflowDraftRepositoryAdapterConfig",
      "database/sql",
      "sql.Open(",
      "pgxpool",
      "oidc.Provider",
      "ValidateWorkflowDraftToken",
      "workflow_saved_draft_production_api"
    ],
    "forbid_sql_files_under": [
      "services/platform/migrations/workflow_saved_drafts"
    ]
  },
  "required_doc_references": [
    {
      "path": "docs/features/workflow/saved-workflow-draft-repository-mode-enablement-v1.md",
      "must_contain": [
        "draft_repository_mode_enablement_review_defined",
        "workflow-saved-draft-repository-mode-enablement-v1",
        "repository_store_disabled"
      ]
    },
    {
      "path": "docs/features/workflow/README.md",
      "must_contain": [
        "Saved Workflow Draft Repository Mode Enablement v1",
        "draft_repository_mode_enablement_review_defined"
      ]
    },
    {
      "path": "docs/features/workflow/saved-workflow-draft-v1.md",
      "must_contain": [
        "Saved Workflow Draft Repository Mode Enablement v1",
        "draft_repository_mode_enablement_review_defined"
      ]
    },
    {
      "path": "docs/radishmind-current-focus.md",
      "must_contain": [
        "workflow-saved-draft-repository-mode-enablement-v1",
        "draft_repository_mode_enablement_review_defined"
      ]
    },
    {
      "path": "docs/radishmind-product-scope.md",
      "must_contain": [
        "workflow-saved-draft-repository-mode-enablement-v1",
        "draft_repository_mode_enablement_review_defined"
      ]
    },
    {
      "path": "docs/task-cards/README.md",
      "must_contain": [
        "Workflow Saved Draft Repository Mode Enablement",
        "workflow-saved-draft-repository-mode-enablement-v1"
      ]
    },
    {
      "path": "scripts/README.md",
      "must_contain": [
        "check-workflow-saved-draft-repository-mode-enablement-v1.py",
        "workflow-saved-draft-repository-mode-enablement-v1.json"
      ]
    },
    {
      "path": "docs/features/workflow/README.md",
      "must_contain": [
        "workflow-saved-draft-repository-mode-enablement-v1",
        "draft_repository_mode_enablement_review_defined"
      ]
    },
    {
      "path": "docs/devlogs/2026-W25.md",
      "must_contain": [
        "workflow-saved-draft-repository-mode-enablement-v1",
        "draft_repository_mode_enablement_review_defined"
      ]
    }
  ],
  "testing_strategy": {
    "status": "repository_mode_enablement_checker_only_no_runtime_enablement",
    "required_checks": [
      "go test ./internal/httpapi",
      "workflow_saved_draft_repository_mode_enablement_checker",
      "workflow_saved_draft_adapter_smoke_checker",
      "workflow_saved_draft_production_auth_runtime_checker",
      "./scripts/check-repo.sh --fast",
      "./scripts/check-repo.sh"
    ],
    "does_not_start_service": true,
    "does_not_enable_repository_store_mode": true,
    "does_not_connect_database": true,
    "does_not_run_sql": true,
    "does_not_call_oidc": true,
    "does_not_validate_token": true,
    "does_not_create_membership_adapter": true,
    "does_not_create_production_api": true
  }
}
