      "required": true,
      "allowed_for_success_reference": [
        "not_required",
        "reviewed_pass"
      ],
      "blocked_statuses": [
        "pending_review",
        "blocked"
      ],
      "failure_code": "image_artifact_safety_review_not_passed"
    },
    {
      "id": "provenance",
      "source_paths": [
        "provenance.source_request_id",
        "provenance.trace_ids",
        "provenance.backend_request_id",
        "provenance.intent_id"
