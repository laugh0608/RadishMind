      "command": "./scripts/run-python.sh scripts/checks/control_plane/check-control-plane-read-shared-shell-v1.py"
    },
    {
      "id": "consumer_smoke",
      "status": "required_now",
      "command": "./scripts/run-python.sh scripts/run-control-plane-read-consumer-smoke.py --check"
    },
    {
      "id": "repo_fast",
      "status": "required_now",
      "command": "macOS/Linux/WSL: ./scripts/check-repo-fast.sh; Windows/PowerShell: pwsh ./scripts/check-repo.ps1 -Fast"
    },
    {
      "id": "product_app_build",
      "status": "required_when_node_dependencies_available",
      "command": "npm run build",
      "working_directory": "apps/radishmind-web/"
    }
  ],
  "implementation_stop_lines": [
    "do not modify apps/radishmind-console into formal user workspace",
