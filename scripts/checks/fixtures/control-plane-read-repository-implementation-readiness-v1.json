  "implementation_gates": [
    {
      "id": "repository_contract_types_defined",
      "status": "required_before_implementation",
      "must_cover": [
        "ReadRepositoryContext",
        "route-owned request fields",
        "sanitized result envelope",
        "ControlPlaneReadRepository"
      ]
    },
    {
      "id": "auth_context_injection_ready",
      "status": "required_before_implementation",
      "must_cover": [
        "tenant_ref from auth context",
        "subject_ref from auth context",
        "scope grants projection",
        "audit_ref binding",
        "fail-closed missing identity"
      ]
    },
    {
      "id": "store_selection_guard_ready",
      "status": "required_before_implementation",
      "must_cover": [
        "fixture-backed fake store remains default",
        "database/postgres/repository mode remains disabled until explicit future slice",
        "database_read_disabled retained",
        "no fallback from database mode to fake store"
      ]
    },
    {
      "id": "schema_and_migration_plan_ready",
