        "database schema ownership",
        "migration rollback plan",
        "tenant index strategy",
        "read-only connection role"
      ]
    },
    {
      "id": "dual_smoke_ready",
      "status": "required_before_implementation",
      "must_cover": [
        "existing fake-store route smoke retained",
        "repository contract fake adapter smoke",
        "future durable repository adapter smoke",
        "same failure mapping across both paths"
      ]
    },
    {
      "id": "production_auth_ready",
      "status": "not_satisfied",
      "must_cover": [
        "Radish OIDC issuer discovery",
        "token validation contract",
        "claim mapping",
        "tenant binding",
        "scope projection"
      ]
    }
  ],
