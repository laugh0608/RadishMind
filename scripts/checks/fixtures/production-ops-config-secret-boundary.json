{
  "schema_version": 1,
  "kind": "production_ops_config_secret_boundary",
  "slice": {
    "id": "config-secret-boundary",
    "track": "Production Ops Hardening v1",
    "status": "governance_boundary_satisfied",
    "does_not_claim": [
      "production_ready",
      "production_secret_backend_ready",
      "production_provider_health_ready",
      "process_supervisor_ready",
      "console_production_package_ready"
    ]
  },
  "config_sources": [
    {
      "id": "local_defaults",
      "environment": "local",
      "status": "supported",
      "source_order": "default",
      "allowed_inputs": [
        "compiled defaults",
        "mock provider",
        "local wrapper defaults"
      ],
      "secret_policy": "must_not_require_or_store_credentials",
      "readiness_scope": "local_readiness_only"
    },
    {
      "id": "developer_config_file",
      "environment": "dev",
      "status": "supported",
      "source_order": "config file",
      "allowed_inputs": [
        "RADISHMIND_PLATFORM_CONFIG",
        "tmp/radishmind-platform.local.json"
      ],
      "secret_policy": "may reference local developer credentials only when the file is untracked",
      "readiness_scope": "developer_smoke_only"
    },
    {
      "id": "developer_env_override",
      "environment": "dev",
      "status": "supported",
      "source_order": "env",
      "allowed_inputs": [
        "RADISHMIND_PLATFORM_PROVIDER",
        "RADISHMIND_PLATFORM_PROVIDER_PROFILE",
        "RADISHMIND_PLATFORM_MODEL",
        "RADISHMIND_PLATFORM_BASE_URL",
        "RADISHMIND_PLATFORM_API_KEY"
      ],
      "secret_policy": "raw credential values must stay outside committed files and sanitized outputs",
      "readiness_scope": "developer_smoke_only"
    },
    {
      "id": "production_secret_backend",
      "environment": "production",
      "status": "not_satisfied",
      "source_order": "future secret backend",
      "allowed_inputs": [],
      "secret_policy": "not implemented in this slice",
      "readiness_scope": "blocked_until_secret_backend_environment_isolation_and_supervisor_exist"
    }
  ],
  "secret_boundaries": {
    "committed_secret_fields_forbidden": [
      "api_key",
      "token",
      "cookie",
      "authorization",
      "credential"
    ],
    "allowed_secret_injection": [
      "RADISHMIND_PLATFORM_API_KEY",
      "provider profile API key environment variables"
    ],
    "sanitized_outputs": [
      "config-summary",
      "config-check",
      "diagnostics",
      "provider inventory"
    ],
    "required_sanitized_fields": [
      "credential_state",
      "base_url_configured",
      "secret_fields",
      "field_sources"
    ],
    "raw_values_must_not_appear": [
      "api key",
      "token",
      "cookie",
      "authorization header",
      "provider base URL"
    ]
  },
  "provider_profile_boundaries": [
    {
      "id": "mock",
      "credential_state": "not_required",
      "production_use": "forbidden",
      "readiness_scope": "local_dev_only"
    },
    {
      "id": "ollama",
      "credential_state": "optional_missing_or_configured",
      "production_use": "blocked_until_environment_isolation_and_supervisor_exist",
      "readiness_scope": "local_daemon_or_dev_smoke"
    },
    {
      "id": "remote_api_provider",
      "credential_state": "must_be_configured_before_use",
      "production_use": "blocked_until_secret_backend_and_provider_health_policy_exist",
      "readiness_scope": "dev_smoke_only"
    }
  ],
  "blocked_conditions": [
    {
      "id": "production_secret_backend",
      "status": "not_satisfied",
      "required_before_production_ready": true
    },
    {
      "id": "production_environment_isolation",
      "status": "not_satisfied",
      "required_before_production_ready": true
    },
    {
      "id": "production_provider_health_policy",
      "status": "not_satisfied",
      "required_before_production_ready": true
    }
  ],
  "evidence": [
    "services/platform/internal/config/config.go",
    "scripts/check-platform-config.py",
    "scripts/check-platform-deployment-smoke.py",
    "scripts/check-platform-diagnostics.py",
    "services/platform/README.md",
    "docs/task-cards/production-ops-hardening-v1-plan.md"
  ],
  "required_consumers": [
    "scripts/check-production-ops-config-secret-boundary.py",
    "scripts/check-repo.py",
    "scripts/check-p3-local-product-shell-short-close-checklist.py",
    "scripts/README.md",
    "docs/radishmind-roadmap.md"
  ]
}
