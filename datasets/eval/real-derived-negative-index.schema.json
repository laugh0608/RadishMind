{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/datasets/eval/real-derived-negative-index.schema.json",
  "title": "RealDerivedNegativeIndex",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "task",
    "record_manifest_path",
    "negative_sample_dir",
    "collection_batch",
    "source",
    "summary",
    "source_record_groups",
    "violation_groups",
    "pattern_groups",
    "unlinked_derived_records"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "string",
      "enum": [
        "radish",
        "radishflow"
      ]
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "record_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "negative_sample_dir": {
      "type": "string",
      "minLength": 1
    },
    "collection_batch": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "captured_candidate_response",
        "simulated_candidate_response"
      ]
    },
    "capture_origin": {
      "type": "string",
      "enum": [
        "interactive_session",
        "adapter_debug_dump",
        "manual_fixture"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derived_record_count",
        "linked_negative_sample_count",
        "source_manifest_count",
        "source_record_count",
        "source_record_group_count",
        "violation_group_count",
        "pattern_group_count",
        "unlinked_derived_record_count"
      ],
      "properties": {
        "derived_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "linked_negative_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_manifest_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_record_group_count": {
          "type": "integer",
          "minimum": 0
        },
        "violation_group_count": {
          "type": "integer",
          "minimum": 0
        },
        "pattern_group_count": {
          "type": "integer",
          "minimum": 0
        },
        "unlinked_derived_record_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "source_record_groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_record_group"
      }
    },
    "violation_groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/violation_group"
      }
    },
    "pattern_groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pattern_group"
      }
    },
    "unlinked_derived_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unlinked_derived_record"
      }
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "linked_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derived_record_id",
        "derived_sample_id",
        "derived_record_path",
        "negative_sample_id",
        "negative_sample_path",
        "source_manifest_path",
        "source_collection_batch",
        "source_record_id",
        "source_sample_id",
        "source_record_path",
        "source_source",
        "derived_patterns",
        "expected_candidate_violations"
      ],
      "properties": {
        "derived_record_id": {
          "type": "string",
          "minLength": 1
        },
        "derived_sample_id": {
          "type": "string",
          "minLength": 1
        },
        "derived_record_path": {
          "type": "string",
          "minLength": 1
        },
        "negative_sample_id": {
          "type": "string",
          "minLength": 1
        },
        "negative_sample_path": {
          "type": "string",
          "minLength": 1
        },
        "source_manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "source_collection_batch": {
          "type": "string",
          "minLength": 1
        },
        "source_record_id": {
          "type": "string",
          "minLength": 1
        },
        "source_sample_id": {
          "type": "string",
          "minLength": 1
        },
        "source_record_path": {
          "type": "string",
          "minLength": 1
        },
        "source_source": {
          "type": "string",
          "enum": [
            "captured_candidate_response",
            "simulated_candidate_response"
          ]
        },
        "source_capture_origin": {
          "type": "string",
          "enum": [
            "interactive_session",
            "adapter_debug_dump",
            "manual_fixture"
          ]
        },
        "derived_patterns": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "expected_candidate_violations": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "source_record_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "source_manifest_path",
        "source_collection_batch",
        "source_record_id",
        "source_sample_id",
        "source_record_path",
        "source_source",
        "entry_count",
        "entries"
      ],
      "properties": {
        "group_id": {
          "type": "string",
          "pattern": "^source-[0-9]{3}$"
        },
        "source_manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "source_collection_batch": {
          "type": "string",
          "minLength": 1
        },
        "source_record_id": {
          "type": "string",
          "minLength": 1
        },
        "source_sample_id": {
          "type": "string",
          "minLength": 1
        },
        "source_record_path": {
          "type": "string",
          "minLength": 1
        },
        "source_source": {
          "type": "string",
          "enum": [
            "captured_candidate_response",
            "simulated_candidate_response"
          ]
        },
        "source_capture_origin": {
          "type": "string",
          "enum": [
            "interactive_session",
            "adapter_debug_dump",
            "manual_fixture"
          ]
        },
        "entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/linked_entry"
          }
        }
      }
    },
    "violation_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "expected_candidate_violations",
        "entry_count",
        "entries"
      ],
      "properties": {
        "group_id": {
          "type": "string",
          "pattern": "^group-[0-9]{3}$"
        },
        "expected_candidate_violations": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/linked_entry"
          }
        }
      }
    },
    "pattern_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "derived_patterns",
        "entry_count",
        "entries"
      ],
      "properties": {
        "group_id": {
          "type": "string",
          "pattern": "^pattern-[0-9]{3}$"
        },
        "derived_patterns": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/linked_entry"
          }
        }
      }
    },
    "unlinked_derived_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derived_record_id",
        "derived_sample_id",
        "derived_record_path",
        "source_manifest_path",
        "source_collection_batch",
        "source_record_id",
        "source_sample_id",
        "source_record_path",
        "source_source",
        "derived_patterns"
      ],
      "properties": {
        "derived_record_id": {
          "type": "string",
          "minLength": 1
        },
        "derived_sample_id": {
          "type": "string",
          "minLength": 1
        },
        "derived_record_path": {
          "type": "string",
          "minLength": 1
        },
        "source_manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "source_collection_batch": {
          "type": "string",
          "minLength": 1
        },
        "source_record_id": {
          "type": "string",
          "minLength": 1
        },
        "source_sample_id": {
          "type": "string",
          "minLength": 1
        },
        "source_record_path": {
          "type": "string",
          "minLength": 1
        },
        "source_source": {
          "type": "string",
          "enum": [
            "captured_candidate_response",
            "simulated_candidate_response"
          ]
        },
        "source_capture_origin": {
          "type": "string",
          "enum": [
            "interactive_session",
            "adapter_debug_dump",
            "manual_fixture"
          ]
        },
        "derived_patterns": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    }
  }
}
