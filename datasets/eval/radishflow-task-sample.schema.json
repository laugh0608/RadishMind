{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/datasets/eval/radishflow-task-sample.schema.json",
  "title": "RadishFlowTaskEvalSample",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sample_id",
    "project",
    "task",
    "input_request",
    "expected_response_shape",
    "evaluation",
    "golden_response"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "const": "radishflow"
    },
    "task": {
      "type": "string",
      "enum": [
        "explain_diagnostics",
        "suggest_flowsheet_edits",
        "suggest_ghost_completion",
        "explain_control_plane_state"
      ]
    },
    "input_request": {
      "type": "object"
    },
    "expected_response_shape": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requires_summary",
        "requires_answers",
        "requires_issues",
        "requires_citations",
        "allow_proposed_actions"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "failed"
          ]
        },
        "requires_summary": {
          "type": "boolean"
        },
        "requires_answers": {
          "type": "boolean"
        },
        "requires_issues": {
          "type": "boolean"
        },
        "requires_citations": {
          "type": "boolean"
        },
        "allow_proposed_actions": {
          "type": "boolean"
        },
        "required_answer_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "required_action_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_risk_level",
        "must_have_json_paths",
        "must_not_have_json_paths",
        "scoring_focus"
      ],
      "properties": {
        "expected_risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "must_have_json_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_not_have_json_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ordered_action_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "id"
            ],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "ordered_parameter_update_keys": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action_index",
              "keys"
            ],
            "properties": {
              "action_index": {
                "type": "integer",
                "minimum": 0
              },
              "keys": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "uniqueItems": true
              }
            }
          }
        },
        "ordered_spec_placeholder_sequences": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action_index",
              "values"
            ],
            "properties": {
              "action_index": {
                "type": "integer",
                "minimum": 0
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "uniqueItems": true
              }
            }
          }
        },
        "scoring_focus": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
            "schema_validity",
            "field_completeness",
            "citation_hit",
            "actionability",
            "risk_level",
            "fact_grounding",
            "hypothesis_labeling",
            "ghost_candidate_legality",
            "ghost_tab_accept",
            "empty_suggestion_boundary",
            "pending_ghost_semantics"
          ]
        },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "candidate_response": {
      "$ref": "#/$defs/golden_response"
    },
    "golden_response": {
      "$ref": "#/$defs/golden_response"
    }
  },
  "$defs": {
    "golden_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "project",
        "task",
        "summary",
        "answers",
        "issues",
        "proposed_actions",
        "citations",
        "confidence",
        "risk_level",
        "requires_confirmation"
      ],
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "failed"
          ]
        },
        "project": {
          "type": "string",
          "const": "radishflow"
        },
        "task": {
          "type": "string",
          "enum": [
            "explain_diagnostics",
            "suggest_flowsheet_edits",
            "suggest_ghost_completion",
            "explain_control_plane_state"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "text"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "citation_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              }
            }
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "message",
              "severity"
            ],
            "properties": {
              "code": {
                "type": "string",
                "minLength": 1
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "error"
                ]
              },
              "citation_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              }
            }
          }
        },
        "proposed_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "kind",
              "label"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "enum": [
                  "artifact",
                  "context",
                  "retrieval",
                  "rule"
                ]
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "locator": {
                "type": "string"
              },
              "excerpt": {
                "type": "string"
              },
              "source_uri": {
                "type": "string"
              }
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "requires_confirmation": {
          "type": "boolean"
        }
      }
    }
  }
}
