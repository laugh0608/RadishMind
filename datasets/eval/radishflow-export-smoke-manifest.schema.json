{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/datasets/eval/radishflow-export-smoke-manifest.schema.json",
  "title": "RadishFlowExportSmokeManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pipeline",
    "project",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "pipeline": {
      "type": "string",
      "const": "radishflow-export-smoke"
    },
    "project": {
      "type": "string",
      "const": "radishflow"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_snapshot"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "export_snapshot": {
          "$ref": "#/$defs/repo_path"
        },
        "expected_adapter_snapshot": {
          "$ref": "#/$defs/repo_path"
        },
        "expected_request_sample": {
          "$ref": "#/$defs/repo_path"
        },
        "strict_validator": {
          "type": "boolean"
        }
      }
    }
  }
}
