      "target": {
        "type": "unit",
        "id": "pump-12"
      },
      "patch": {
        "parameter_updates": {
          "outlet_pressure_target_kpa": {
            "action": "review_and_raise_above_inlet",
            "minimum_reference_stream_id": "feed-81"
