      "kind": "candidate_edit",
      "title": "为 Separator Liquid 92 添加下游连接占位而不指定具体去向",
      "rationale": "该液相流当前没有下游 consumer 或 export sink，造成拓扑无效；但诊断同时指出其路由仍依赖当前泵出口与分离器压力上下文。基于证据不足，不应臆造具体目标设备，仅应提出连接占位以待人工确认。",
      "risk_level": "high",
      "requires_confirmation": true,
      "citation_ids": [
        "diag-1",
        "diag-5",
        "flowdoc-stream-3",
        "flowdoc-unit-2",
        "flowdoc-stream-2",
        "flowdoc-unit-1",
        "snapshot-1"
      ],
      "target": {
        "type": "stream",
        "id": "separator-liquid-92"
      },
      "patch": {
        "connection_placeholder": {
          "expected_downstream_kind": "consumer_or_export_sink",
          "requires_manual_binding": true,
          "retain_existing_source_binding": true
        }
      }
    },
    {
      "kind": "candidate_edit",
      "title": "为 Booster Pump 提议提高出口压力目标并保留效率修正占位",
      "rationale": "当前泵入口流 pressure_kpa=200，而泵配置中的 outlet_pressure_target_kpa=150，直接触发出口压力目标无效诊断；同时 efficiency_percent=109 超出推荐范围。基于现有证据，最小可审查提案是把出口压力目标调整到高于入口压力的待确认值，并把效率修正限制为占位而非武断替换具体数值。",
      "risk_level": "medium",
      "requires_confirmation": true,
      "citation_ids": [
        "diag-2",
        "diag-4",
        "flowdoc-unit-1"
      ],
      "target": {
        "type": "unit",
        "id": "pump-13"
      },
      "patch": {
        "parameter_updates": {
          "outlet_pressure_target_kpa": {
            "action": "review_and_raise_above_inlet",
            "minimum_reference_stream_id": "feed-92"
          },
          "efficiency_percent": {
            "action": "clamp_to_review_range",
            "suggested_range": [
              60,
              85
            ]
          }
        },
        "preserve_topology": true
      }
    },
    {
      "kind": "candidate_edit",
      "title": "为 Product Separator 补充固定压力目标占位",
      "rationale": "分离器已处于 fixed pressure 模式，但 operating pressure target 缺失，存在直接错误诊断。现有文档仅能确认上游泵出口流和液相出口流的压力上下文，尚不足以唯一确定分离器目标压力，因此建议仅补充待确认的局部参数占位。",
      "risk_level": "medium",
      "requires_confirmation": true,
      "citation_ids": [
        "diag-3",
        "flowdoc-unit-2",
        "flowdoc-stream-3",
        "flowdoc-unit-1",
        "snapshot-1"
      ],
      "target": {
        "type": "unit",
        "id": "separator-10"
      },
      "patch": {
        "parameter_placeholders": [
          "operating_pressure_kpa",
          "operating_pressure_target_kpa"
        ],
        "patch_scope": "unit_parameters",
        "preserve_existing_connections": true
      }
    }
