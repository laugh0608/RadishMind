      "message": "Liquid Product is not connected to any downstream consumer or export sink.",
      "severity": "error",
      "citation_ids": [
        "diag-1",
        "flowdoc-stream-2",
        "snapshot-1"
      ]
    },
    {
      "code": "STREAM_SPEC_MISSING",
      "message": "Vapor Product is missing temperature specification.",
      "severity": "error",
      "citation_ids": [
