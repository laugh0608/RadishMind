      ]
    }
  ],
  "proposed_actions": [
    {
      "kind": "candidate_edit",
      "title": "为液相产品流添加下游连接占位符",
      "rationale": "液相产品流当前无下游连接，导致求解器报告无效拓扑。添加 connection_placeholder 以标记待连接目标，保留用户后续指定具体单元的灵活性。",
      "risk_level": "high",
      "requires_confirmation": true,
      "citation_ids": [
        "diag-1",
        "flowdoc-stream-2",
        "snapshot-1"
      ],
      "target": {
        "type": "stream",
        "id": "liquid-product-5"
      },
      "patch": {
        "connection_placeholder": {
          "expected_downstream_kind": "consumer_or_export_sink",
          "requires_manual_binding": true,
          "retain_existing_source_binding": true
        }
      }
    },
    {
      "kind": "candidate_edit",
      "title": "为气相产品流补全温度规格",
      "rationale": "气相产品流已指定压力但缺少温度，导致自由度不足。基于闪蒸罐典型操作假设，建议以进料温度 46°C 作为初始占位值，用户可后续调整。",
      "risk_level": "medium",
      "requires_confirmation": true,
      "citation_ids": [
        "diag-2",
        "flowdoc-stream-3"
      ],
      "target": {
        "type": "stream",
        "id": "vapor-product-5"
      },
      "patch": {
        "spec_placeholders": [
          "temperature_c"
        ],
        "retain_existing_specs": true
      }
    }
  ],
