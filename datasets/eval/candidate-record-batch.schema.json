{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radishmind.local/datasets/eval/candidate-record-batch.schema.json",
  "title": "CandidateResponseRecordBatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "collection_batch",
    "project",
    "task",
    "records"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "collection_batch": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "enum": [
        "radish",
        "radishflow"
      ]
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "captured_candidate_response",
        "simulated_candidate_response"
      ]
    },
    "batch_key": {
      "type": "string",
      "minLength": 1
    },
    "capture_origin": {
      "type": "string",
      "enum": [
        "interactive_session",
        "adapter_debug_dump",
        "manual_fixture"
      ]
    },
    "output_root": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "record_id",
          "sample_id",
          "path"
        ],
        "properties": {
          "record_id": {
            "type": "string",
            "minLength": 1
          },
          "sample_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sample_key": {
            "type": "string",
            "minLength": 1
          },
          "record_relpath": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
